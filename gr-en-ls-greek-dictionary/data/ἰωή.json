{"word":"ἰωή","slug":"ἰωή","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n51553\" key=\"i)wh/\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἰωή</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <sense id=\"n51553.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">any loud sound: shout</tr_>, or <tr_ opt=\"n\" TEIform=\"tr\">cry</tr_> of men or women, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">περὶ φρένας ἤλυθ᾽ ἰωή</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:10:139\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">10.139</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὦρτο δ᾽ ἰ. λεπταλέη ὀδυρομένων</quote_> <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:3:708\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">3.708</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ἰ. δενδρώδης</foreign> (of Daphne) <bibl n=\"urn:cts:greekLit:tlg2045.tlg001.perseus-grc1:15:300\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Nonn.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></title_> <biblScope TEIform=\"biblScope\">15.300</biblScope> </bibl>; <tr_ opt=\"n\" TEIform=\"tr\">sound</tr_> of the lyre, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">περὶ δέ σφεας ἤλυθ᾽ ἰωὴ φόρμιγγος</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:17:261\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">17.261</biblScope> </bibl> </cit>; of the wind, <foreign lang=\"greek\" TEIform=\"foreign\">ὑπὸ Ζεφ