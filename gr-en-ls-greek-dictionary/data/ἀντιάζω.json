.tlg001.perseus-grc1:4:80\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">4.80</biblScope></bibl></cit>,<bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:9:6\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9.6</biblScope> </bibl>; but these two tenses belong also to <foreign lang=\"greek\" TEIform=\"foreign\">ἀντιάω</foreign> : (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">ἀντί</etym>):—<tr_ opt=\"n\" TEIform=\"tr\">meet face to face</tr_>: </sense> <sense n=\"I\" id=\"n9780.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> c. acc. pers., <tr_ opt=\"n\" TEIform=\"tr\">encounter,</tr_> whether as friend or foe, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὸν ἐπιόντα</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:4:118\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">4.118</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:2:141\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2.141</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:4:80\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">4.80</biblScope></bibl>, etc.; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀ. [τινὰ] ἐς τόπον</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:166\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.166</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:9:6\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9.6</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πατέρ᾽ ἀντιάσασα πρὸς . . πόρθμευμα</quote_> <bibl n=\"urn:cts:gree