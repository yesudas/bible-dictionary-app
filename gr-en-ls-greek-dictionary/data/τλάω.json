rseus-grc1:753\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ch.\">Ch.</a></title_> <biblScope TEIform=\"biblScope\">753</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0011.tlg007.perseus-grc1:1077\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ OC\">OC</a></title_> <biblScope TEIform=\"biblScope\">1077</biblScope> </bibl> (lyr.), <bibl n=\"urn:cts:greekLit:tlg0011.tlg001.perseus-grc1:71\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tr.\">Tr.</a></title_> <biblScope TEIform=\"biblScope\">71</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0006.tlg007.perseus-grc1:1251\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Hec.\">Hec.</a></title_> <biblScope TEIform=\"biblScope\">1251</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n104119.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> c. <mood opt=\"n\" TEIform=\"mood\"><a class=\"S\" href=\"S:LSJ inf.\">inf.</a></mood>, <tr_ opt=\"n\" TEIform=\"tr\">dare</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">venture to do</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὔτε λόχονδ᾽ ἰέναι τέτληκας θυμῷ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:228\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.228</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:7:480\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">7.480</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:21:150\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">21.150</biblScope></bibl>, etc.; <tr_ opt=\"n\" TEIform=\"tr\">bring oneself to do something contrary to one's feelings</tr_>, whether good or bad, <tr_ opt=\"n\" TEIform=\"tr\">have the courage, hardihood, effrontery, cruelty</tr_>, or <tr_ opt=\"n\" TEIform=\"tr\">the grace, charity, patience</tr_>, to do anything, <foreign lang=\"greek\" TEIform=\"foreign\">ἔστε δὴ πατρὶ ἔτλην γεγωνεῖν νυκτίφοιτα δείματα</foreign> <tr_ opt=\"n\" TEIform=\"tr\">I took courage</tr_> to . ., <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:657\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">657</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἔτλα θυτὴρ γενέσθαι θυγατρός</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:224\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">224</biblScope> </bibl> </cit> (lyr.); <foreign lang=\"greek\" TEIform=\"foreign\">ἔτλα . . φῶς ἀλλάξαι</foreign> <tr_ opt=\"n\" TEIform=\"tr\">submitted</tr_> to exchange . ., <bibl n=\"urn:cts:greekLit:tlg0011.tlg002.perseus-grc1:944\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ant.\">Ant.</a></title_> <biblScope TEIform=\"biblScope\">944</biblScope> </bibl> (lyr.); <foreign lang=\"greek\" TEIform=\"foreign\">πῶς ἔτλης σὰς ὄψεις μαρᾶναι</foreign>; how <tr_ opt=\"n\" TEIform=\"tr\">couldst thou</tr_> quench thy orbs of sight? <bibl n=\"urn:cts:greekLit:tlg0011.tlg004.perseus-grc1:1327\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ OT\">OT</a></title_> <b