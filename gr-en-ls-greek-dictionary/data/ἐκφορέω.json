3\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">47.53</biblScope></bibl>,<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">75</biblScope></bibl>. </sense> <sense n=\"8\" id=\"n33194.7\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">make away with</tr_>, <bibl n=\"http://www.trismegistos.org/text/13783\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PSI\">PSI</a></title_> <biblScope TEIform=\"biblScope\">5.463</biblScope> </bibl> <date TEIform=\"date\">(ii A.D.)</date>, <bibl n=\"Perseus:abo:pap,P.Oxy.:1642:22\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ POxy.\">POxy.</a></title_> <biblScope TEIform=\"biblScope\">1642.22</biblScope> </bibl> <date TEIform=\"date\">(iii A.D.)</date>. </sense> <sense n=\"9\" id=\"n33194.8\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">ἐκφορεῖ· σπανίζει ὑπάρχοντα</foreign>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl> </sense> </entryFree>"}]}