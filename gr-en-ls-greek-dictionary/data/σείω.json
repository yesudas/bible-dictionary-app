> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ POxy.\">POxy.</a></author> <biblScope TEIform=\"biblScope\">1252r</biblScope></bibl>.<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">37</biblScope> </bibl> <date TEIform=\"date\">(iii A.D.)</date>. </sense> <sense n=\"II\" id=\"n93601.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">shake, heave, quake</tr_>, of the earth, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐσσείοντο πόδες Ἴδης</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:20:59\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">20.59</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">Δῆλος . . πρῶτα καὶ ὕστατα . . σεισθεῖσα</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:6:98\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">6.98</biblScope> </bibl> </cit>: metaph., <tr_ opt=\"n\" TEIform=\"tr\">to be shaken to its foundation</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὸ τερπνὸν πιτνεῖ . . σεσεισμένον</quote_> <bibl n=\"urn:cts:greekLit:tlg0033.tlg002.perseus-grc1:8:94\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ P.\">P.</a></title_> <biblScope TEIform=\"biblScope\">8.94</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οἷς . . ἂν σεισθῇ θεόθεν δόμος</quote_> <bibl n=\"urn:cts:greekLit:tlg0011.tlg002.perseus-grc1:584\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a clas