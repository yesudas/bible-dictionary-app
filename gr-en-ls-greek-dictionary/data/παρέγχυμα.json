{"word":"παρέγχυμα","slug":"παρέγχυμα","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n79200\" key=\"pare/gxuma\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"suff\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">παρέγ-χῠμα</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ατος</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">τό</gen>, <sense id=\"n79200.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">anything poured in beside</tr_>, name given by Erasistratus to the peculiar substance of the lungs, liver, kidneys, and spleen, as if <tr_ opt=\"n\" TEIform=\"tr\">formed separately</tr_> by the veins that run into them, the word <foreign lang=\"greek\" TEIform=\"foreign\">σάρξ</foreign> being used of the muscular flesh, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Gal.\">Gal.</a></author> <biblScope TEIform=\"biblScope\">14.697</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0732.tlg002:2:72\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Alex.Aphr.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">2.72</biblScope></bibl>.</sense> </entryFree>"}]}