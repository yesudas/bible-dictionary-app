l n=\"urn:cts:greekLit:tlg0565.tlg003:12:506C\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Sor.</author> <title_ TEIform=\"title\">Fasc.</title_> <biblScope TEIform=\"biblScope\">12.506C.</biblScope> </bibl> </cit>: neut. pl. as <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos>, <foreign lang=\"greek\" TEIform=\"foreign\">ἐπικάρσια</foreign> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">δὴ προπεσοῦμαι</quote_> <tr_ opt=\"n\" TEIform=\"tr\">athwart,</tr_> <bibl n=\"urn:cts:greekLit:tlg0408.tlg001:640\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Com.Adesp.\">Com.Adesp.</a></author> <biblScope TEIform=\"biblScope\">640</biblScope></bibl></cit>. Regul. <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos> <foreign lang=\"greek\" TEIform=\"foreign\">-ίως</foreign> <tr_ opt=\"n\" TEIform=\"tr\">transversely</tr_>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Antyll.</author> </bibl> ap. <bibl n=\"urn:cts:greekLit:tlg0722.tlg001:44:8:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Orib.</author> <biblScope TEIform=\"biblScope\">44.8.2</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0715.tlg001:6:40\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Paul.Aeg.</author> <biblScope TEIform=\"biblScope\">6.40</biblScope></bibl>. </sense><sense n=\"2\" id=\"n39575.1\" level=\"3\" opt=\"n\" TEIform=\"sense\">. <tr_ opt=\"n\" TEIform=\"tr\">striped</tr_>, <bibl n=\"Perseus:abo:pap,CPR:21:19\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ CPR\">CPR</a></title_> <biblScope TEIform=\"biblScope\">21.19</biblScope> </bibl> <date TEIform=\"date\">(iii A.D.)</date>, etc. </sense><sense n=\"II\" id=\"n39575.2\" level=\"2\" opt=\"n\" TEIform=\"sense\">. in <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:70\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=