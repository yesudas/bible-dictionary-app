{"word":"σφαλλός","slug":"σφαλλός","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n101610\" key=\"sfallo/s\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">σφαλλός</orth> or <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">σφᾰλός</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ὁ</gen>, <sense id=\"n101610.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">a round leaden plate</tr_>, which was thrown by a strap attached to a ring, a variety of the <foreign lang=\"greek\" TEIform=\"foreign\">δίσκος</foreign>, <bibl n=\"urn:cts:greekLit:tlg0542.tlg001:8:72\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Poll.</author> <biblScope TEIform=\"biblScope\">8.72</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl> </sense> <sense n=\"II\" id=\"n101610.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">a round block of wood</tr_> with two holes for the feet, <tr_ opt=\"n\" TEIform=\"tr\">pair of stocks</tr_>, <bibl n=\"urn:cts:greekLit:tlg0521.tlg001:148\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Epich.</author> <biblScope TEIform=\"biblScope\">148</biblScope> </bibl> (<foreign lang=\"greek\" TEIform=\"foreign\">σφάκελλος</foreign> codd. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> </bibl>), <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Poll.</author> </bibl> l.c., <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl>; cf. <foreign lang=\"greek\" TEIform=\"foreign\">σφέλας</foreign>.</sense> </entryFree>"}]}