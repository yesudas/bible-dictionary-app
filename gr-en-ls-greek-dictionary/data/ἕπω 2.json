\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">1053</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:0:16\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">0.16</biblScope> </bibl>; <tr_ opt=\"n\" TEIform=\"tr\">accept an invitation,</tr_> <bibl n=\"urn:cts:greekLit:tlg0032.tlg004.perseus-grc1:1:7\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ X.\">X.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Smp.\">Smp.</a></title_> <biblScope TEIform=\"biblScope\">1.7</biblScope> </bibl> ; <foreign lang=\"greek\" TEIform=\"foreign\">ἕ. κακοῖς</foreign> <tr_ opt=\"n\" TEIform=\"tr\">submit</tr_> to them, <bibl n=\"urn:cts:greekLit:tlg0011.tlg001.perseus-grc1:1074\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tr.\">Tr.</a></title_> <biblScope TEIform=\"biblScope\">1074</biblScope></bibl>. </sense> <sense n=\"8\" id=\"n42044.8\" level=\"3\" opt=\"n\" TEIform=\"sense\"> simply, <tr_ opt=\"n\" TEIform=\"tr\">come near, approach,</tr_> in imper., <foreign lang=\"greek\" TEIform=\"foreign\">ἕπεο προτέρω</foreign> <tr_ opt=\"n\" TEIform=\"tr\">come on</tr_> nearer, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:387\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">18.387</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:5:91\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">5.91</biblScope></bibl>. </sense> <sense n=\"9\" id=\"n42044.9\" level=\