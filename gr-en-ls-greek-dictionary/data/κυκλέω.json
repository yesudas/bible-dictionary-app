\"> <tr_ opt=\"n\" TEIform=\"tr\">go round and round, revolve</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὴν αὐτὴν φορὰν κ.</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:617a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">617a</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">χρόνου . . κατ᾽ ἀριθμὸν κυκλουμένου</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg031:38a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ti.\">Ti.</a></title_> <biblScope TEIform=\"biblScope\">38a</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὑμὸς αἰεὶ πότμος ἐν πυκνῷ θεοῦ τροχῷ κυκλεῖται</quote_> <bibl n=\"urn:cts:greekLit:tlg0011.tlg008.perseus-grc1:871\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">871</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὁ βίος ἀγαθοῖς τε καὶ κακοῖς κ. πάντα τὸν αἰῶνα</quote_> <bibl n=\"urn:cts:greekLit:tlg0060.tlg001.perseus-grc3:18:59\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.S.\">D.S.</a></author> <biblScope TEIform=\"biblScope\">18.59</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">δι᾽ ἀλλήλων αὐτοῖς -εῖται τὸ κακόν</foreign>, of the vicious circle in disease, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Gal.\">Gal.</a></author> <biblScope TEIform=\"biblScope\">10.360</biblScope></bibl>. </sense> <sense n=\