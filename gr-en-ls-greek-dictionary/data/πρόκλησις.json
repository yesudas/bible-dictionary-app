_> <bibl n=\"urn:cts:greekLit:tlg0014.tlg040.perseus-grc1:10\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">40.10</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">φεύγειν</foreign> to decline it, <bibl n=\"urn:cts:greekLit:tlg0028.tlg006.perseus-grc1:27\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Antipho\">Antipho</a></author> <biblScope TEIform=\"biblScope\">6.27</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">μαρτυρεῖν</foreign> to appeal to it, <bibl n=\"urn:cts:greekLit:tlg0014.tlg045.perseus-grc1:15\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">45.15</biblScope></bibl>. </sense> <sense n=\"IV\" id=\"n87805.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">titillation, stimulation,</tr_> <bibl n=\"urn:cts:greekLit:tlg0719.tlg003.perseus-grc1:1:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Aret.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ CA\">CA</a></title_> <biblScope TEIform=\"biblScope\">1.2</biblScope></bibl>, al.</sense> </entryFree>"}]}