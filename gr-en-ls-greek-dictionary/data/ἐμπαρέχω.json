{"word":"ἐμπαρέχω","slug":"ἐμπαρέχω","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n34230\" key=\"e)mpare/xw\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἐμπαρ-έχω</orth>, <sense id=\"n34230.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">hand over</tr_> to another, <tr_ opt=\"n\" TEIform=\"tr\">put into</tr_> his <tr_ opt=\"n\" TEIform=\"tr\">power</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὴν πόλιν ἐμπαρασχόντες προκινδυνεῦσαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:7:56\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">7.56</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">μηδὲ τούτῳ ἐμπαράσχητε . . ἐλλαμπρύνεσθαι</foreign> <tr_ opt=\"n\" TEIform=\"tr\">put into</tr_> his <tr_ opt=\"n\" TEIform=\"tr\">power, allow</tr_> him to gain distinction, <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:6:12\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">6.12</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ἐ. ἑαυτόν τινι</foreign> <tr_ opt=\"n\" TEIform=\"tr\">give</tr_> oneself <tr_ opt=\"n\" TEIform=\"tr\">up</tr_> as his tool, <bibl n=\"urn:cts:greekLit:tlg0551.tlg017.perseus-grc1:5:68\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ App.\">App.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ BC\">BC</a></title_> <biblScope TEIform=\"biblScope\">5.68</biblScope> </bibl>; but <foreign lang=\"greek\" TEIform=\"foreign\">ἐμπαρασχεῖν ἑαυτὸν τοιούτῳ τινί</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">δείπνῳ</foreign>) <tr_ opt=\"n\" TEIform=\"tr\">accept an invitation</tr_>, <bibl n=\"urn:cts:greekLit:tlg0062.tlg015:28\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Luc.\">Luc.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Symp.\">Symp.</a></title_> <biblScope TEIform=\"biblScope\">28</biblScope> </bibl>:—<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ποτὶ τὸν θίασον . . εὔνουν ἑαυτὸν -εχόμενος</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Rev.Arch.\">Rev.Arch.</a></title_> <biblScope TEIform=\"biblScope\">22(1925).64</biblScope> </bibl> </cit> (<placeName TEIform=\"placeName\">Callatis</placeName>), cf. <bibl n=\"urn:cts:greekLit:tlg0018.tlg001:2:127\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ph.\">Ph.</a></author> <biblScope TEIform=\"biblScope\">2.127</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n34230.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">supply, furnish</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">ψυχῇ τέρψιν, δυνάμεις τισί</foreign>, <bibl n=\"urn:cts:greekLit:tlg0018.tlg001:1:12\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">1.12</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0018.tlg001:2:383\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2.383</biblScope></bibl>, al.; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὄνομά τινι</quote_> <bibl n=\"urn:cts:greekLit:tlg0007.tlg065:29\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Plu.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Galb.\">Galb.</a></title_> <biblScope TEIform=\"biblScope\">29</biblScope></bibl></cit>.</sense> </entryFree>"}]}