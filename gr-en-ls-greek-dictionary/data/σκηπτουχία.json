{"word":"σκηπτουχία","slug":"σκηπτουχία","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n94803\" key=\"skhptouxi/a\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">σκηπτουχία</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <sense id=\"n94803.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">bearing of a staff</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">sceptre</tr_> as the badge of command, hence <tr_ opt=\"n\" TEIform=\"tr\">military command</tr_>, esp. of the Persians, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐπὶ σκηπτουχίᾳ ταχθείς</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg002.perseus-grc1:297\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pers.\">Pers.</a></title_> <biblScope TEIform=\"biblScope\">297</biblScope> </bibl> </cit>; technically, <tr_ opt=\"n\" TEIform=\"tr\">rank</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">province of a Persian</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">σκηπτοῦχος</foreign> (v. sq. <bibl n=\"urn:cts:greekLit:tlg0085.tlg002.perseus-grc1:2\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2</biblScope> </bibl>), <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:11:2:18\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Str.\">Str.</a></author> <biblScope TEIform=\"biblScope\">11.2.18</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n94803.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> generally, <tr_ opt=\"n\" TEIform=\"tr\">command, power</tr_>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Lyc.\">Lyc.</a></author> <biblScope TEIform=\"biblScope\">111</biblScope></bibl>.</sense> </entryFree>"}]}