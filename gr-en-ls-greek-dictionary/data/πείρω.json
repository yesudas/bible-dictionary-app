grc1:2:434\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2.434</biblScope> </bibl> : abs. in the same sense, <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:326\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">2.326</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:398\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">398</biblScope></bibl>. (Cf. <foreign lang=\"greek\" TEIform=\"foreign\">περόνη</foreign>, OSlav. <tr_ opt=\"n\" TEIform=\"tr\">na-perją</tr_> 'pierce'.)</sense> </entryFree>"}]}