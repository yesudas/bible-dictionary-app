" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">10.124</biblScope></bibl></cit>, cf. Ach. Tat.<bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:3:4\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3.4</biblScope> </bibl> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram> </gramGrp>); <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇ τριαίνῃ . . ἔπειρε καὶ ἀνεῖλε</quote_> <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:13:1:38\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Str.\">Str.</a></author> <biblScope TEIform=\"biblScope\">13.1.38</biblScope> </bibl> </cit> :—<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <foreign lang=\"greek\" TEIform=\"foreign\">σκῆπτρον, δέπας χρυσείοις ἥλοισι πεπαρμένον</foreign>, <tr_ opt=\"n\" TEIform=\"tr\">studded</tr_> with golden nails, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:246\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.246</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:11:633\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11.633</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ὀδύνῃσι πεπαρμένος</foreign> <tr_ opt=\"n\" TEIform=\"tr\">pierced</tr_> with pain, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:5:399\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">5.399</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0232.tlg001:84\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Archil.</author> <biblScope TEIform=\"biblScope\">84</