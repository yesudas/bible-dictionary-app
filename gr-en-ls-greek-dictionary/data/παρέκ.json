"2\" id=\"n79260.5\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">παρὲξ Αχιλῆα</foreign> <tr_ opt=\"n\" TEIform=\"tr\">without the knowledge of</tr_> Achilles, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:24:434\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">24.434</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n79260.6\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">contrary to</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">νόον τινός</quote_> <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:1:130\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">1.130</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">π. Διὸς βουλήν</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:1:1315\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1315</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">π. ἐμὰ θέσφατα βῆναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:341\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">2.341</biblScope></bibl></cit>. </sense> <sense n=\"4\" id=\"n79260.7\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">beside</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πολίσματα π. αὐτὰς Πάτρας ἄλλα</quote_> <bibl n=\"urn:cts:greekLit:tlg0525.tlg001.perseus-grc1:7:18:6\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Paus.</author> <biblScope TEIform=\"biblScope\">7.18.6</biblScope></bibl></cit>. </sense> <sense n=\"5\" id=\"n79260.8\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">except, Supp. Epigr.</tr_> <bibl n=\"urn:cts:greekLit:tlg0525.tlg001.perseus-grc1:2:710:3\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2.710.3</biblScope> </bibl> (Pednelissus, <date TEIform=\"date\">i B. C.</date>). </sense> <sense n=\"B\" id=\"n79260.9\" level=\"1\" opt=\"n\" TEIform=\"sense\"> as <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos>, </sense> <sense n=\"1\" id=\"n79260.10\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of Place, <tr_ opt=\"n\" TEIform=\"tr\">out beside, out and away</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λαβὼνπεριμήκεα κοντὸν ὦσα παρέξ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:488\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">9.488</biblScope> </bibl> </cit> ; <foreign lang=\"greek\" TEIform=\"foreign\">νῆχε παρέξ</foreign> <tr_ opt=\"n\" TEIform=\"tr\">out along shore</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:5:439\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">5.439</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">στῆ δὲ παρέξ</foreign> <tr_ opt=\"n\" TEIform=\"tr\">hard by</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:11:486\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">11.486</biblScope> </bibl> ; <foreign lang=\"greek\" TEIform=\"foreign\">τῆλε παρέξ</foreign> far <tr_ opt=\"n\" TEIform=\"tr\">away</tr_>, <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:272\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">2.272</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n79260.11\" level=\"3\" opt=\"n\" TEIform=\"sense\"> metaph., <tr_ opt=\"n\" TEIform=\"tr\">beside th