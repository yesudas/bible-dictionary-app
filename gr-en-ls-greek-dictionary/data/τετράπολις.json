rathon, Probalinthos, Tricorythos, <bibl n=\"urn:cts:greekLit:tlg0086.tlg051:491\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">491</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0007.tlg001:14\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Plu.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Thes.\">Thes.</a></title_> <biblScope TEIform=\"biblScope\">14</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n103500.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> in Doris, <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:9:4:10\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Str.\">Str.</a></author> <biblScope TEIform=\"biblScope\">9.4.10</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n103500.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> in Syria, <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:16:2:4\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">16.2.4</biblScope></bibl>. </sense> <sense n=\"4\" id=\"n103500.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> in Cephallenia, <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:2:30\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">2.30</biblScope></bibl>.</sense> </entryFree>"}]}