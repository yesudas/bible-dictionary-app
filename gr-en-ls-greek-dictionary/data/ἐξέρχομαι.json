\">476</biblScope> </bibl> </cit>; of an actor, <tr_ opt=\"n\" TEIform=\"tr\">come out</tr_> on the stage, <bibl n=\"urn:cts:greekLit:tlg0019.tlg001.perseus-grc1:240\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ach.\">Ach.</a></title_> <biblScope TEIform=\"biblScope\">240</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0019.tlg006.perseus-grc1:512\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Av.\">Av.</a></title_> <biblScope TEIform=\"biblScope\">512</biblScope> </bibl>: abs., <tr_ opt=\"n\" TEIform=\"tr\">come forth,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐ. καὶ ἀμῦναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:9:576\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">9.576</biblScope></bibl></cit>. </sense> <sense n=\"b\" id=\"n37200.1\" level=\"4\" opt=\"n\" TEIform=\"sense\"> rarely c. acc., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐξῆλθον τὴν Περσίδα χώραν</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:7:29\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">7.29</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐ. τὸ ἄστυ</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:5:104\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">5.104</biblScope></bibl></cit>, cf.<bibl n=\"urn:cts:greekLit:tlg0086.tlg035.perseus-grc1:1285a:5\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class