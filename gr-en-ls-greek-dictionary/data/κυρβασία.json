\"bibl\"> <author TEIform=\"author\">Aret.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ CA\">CA</a></title_> <biblScope TEIform=\"biblScope\">1.10</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n61024.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <abbr TEIform=\"abbr\">=</abbr> Lat. <tr_ opt=\"n\" TEIform=\"tr\">apex</tr_> (of the <tr_ opt=\"n\" TEIform=\"tr\">flamines</tr_>), <bibl n=\"urn:cts:greekLit:tlg0081.tlg001:2:70\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.H.\">D.H.</a></author> <biblScope TEIform=\"biblScope\">2.70</biblScope></bibl>.</sense> </entryFree>"}]}