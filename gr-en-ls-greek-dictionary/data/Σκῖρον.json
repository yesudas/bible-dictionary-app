{"word":"Σκῖρον","slug":"Σκῖρον","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n94931\" key=\"*ski=ron\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">Σκῖρον</orth> or <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">Σκίρον</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">τό</gen>, a suburb of Athens, <foreign lang=\"greek\" TEIform=\"foreign\">Ἀθηναῖοι τρεῖς ἀρότους ἱερ,ὺς ἄγουσι, πρῶτον ἐπὶ Σκίρῳ</foreign> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Plu.</author> <biblScope TEIform=\"biblScope\">2.144a</biblScope> </bibl>; named after the seer <foreign lang=\"greek\" TEIform=\"foreign\">Σκ,<itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">οος</itype></foreign>, <bibl n=\"urn:cts:greekLit:tlg0525.tlg001.perseus-grc1:1:36:4\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Paus.</author> <biblScope TEIform=\"biblScope\">1.36.4</biblScope></bibl>, cf. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl> <sense id=\"n94931.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\"><a class=\"S\" href=\"S:LSJ s.v.\">s.v.</a></lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">Σκειρόμαντις; ἐπὶ Σκίρῳ ἱεροποιία</ref> </xr> <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:9:1:9\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Str.\">Str.</a></author> <biblScope TEIform=\"biblScope\">9.1.9</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐκύβευον ἐπὶ Σκίρῳ ἐν τῷ τῆς Σκιράδος Ἀθηνᾶς νεῷ</quote_> <bibl n=\"urn:cts:greekLit:tlg0542.tlg001:9:96\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Poll.</author> <biblScope TEIform=\"biblScope\">9.96</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tl