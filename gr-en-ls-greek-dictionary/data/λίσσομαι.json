<gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ep.\">Ep.</a></gram></gramGrp>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:394\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.394</biblScope></bibl>, al.; written <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">λλ</itype> after the augm., <abbr TEIform=\"abbr\">v.</abbr> supr.]</sense> </entryFree>"}]}