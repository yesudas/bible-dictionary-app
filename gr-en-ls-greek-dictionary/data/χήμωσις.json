{"word":"χήμωσις","slug":"χήμωσις","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n113884\" key=\"xh/mwsis\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">χήμωσις</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">εως</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <sense id=\"n113884.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">an affection of the eyes,</tr_> when the cornea swells <tr_ opt=\"n\" TEIform=\"tr\">like a cockle-shell</tr_> (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">χήμη</etym>) so as to impede sight, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Gal.\">Gal.</a></author> <biblScope TEIform=\"biblScope\">19.436</biblScope></bibl>, Demosth. Ophth. ap. <bibl n=\"urn:cts:greekLit:tlg0722.tlg004:8:42\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Orib.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Syn.\">Syn.</a></title_> <biblScope TEIform=\"biblScope\">8.42</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0715.tlg001:3:22\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Paul.Aeg.</author> <biblScope TEIform=\"biblScope\">3.22</biblScope></bibl>.</sense> </entryFree>"}]}