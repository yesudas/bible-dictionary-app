\"urn:cts:greekLit:tlg4083.tlg001:1806:37\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1806.37</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">τόμουρε</foreign> <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">=</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">μάντι</ref> </xr> occurs in <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Lyc.\">Lyc.</a></author> <biblScope TEIform=\"biblScope\">223</biblScope></bibl>, cf. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl> </sense> </entryFree>"}]}