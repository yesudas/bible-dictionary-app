greekLit:tlg0542.tlg001:1:85\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Poll.</author> <biblScope TEIform=\"biblScope\">1.85</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n62585.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">drinking-cup</tr_>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Hedyl.</author> </bibl> ap. <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:11:486b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">11.486b</biblScope></bibl>.</sense> </entryFree>"}]}