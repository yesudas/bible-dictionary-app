uote_ lang=\"greek\" TEIform=\"quote\">ἡμῖν ἅ. ἀναπαυομένοις ὁ παῖς ἀναγνώσεται</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg006.perseus-grc1:143b\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tht.\">Tht.</a></title_> <biblScope TEIform=\"biblScope\">143b</biblScope></bibl></cit>. </sense> <sense n=\"4\" id=\"n4845.5\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἅ. μέν . . ἔτι δέ . . </quote_> <bibl n=\"urn:cts:greekLit:tlg0032.tlg007.perseus-grc1:1:4:3\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ X.\">X.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Cyr.\">Cyr.</a></title_> <biblScope TEIform=\"biblScope\">1.4.3</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἅ. μέν . . πρὸς δέ . . </quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:8:51\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">8.51</biblScope></bibl></cit>. </sense> <sense n=\"II\" id=\"n4845.6\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">together, at once, both,</tr_> without direct ref. to time, <foreign lang=\"greek\" TEIform=\"foreign\">ἅ. πάντες</foreign> or <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πάντες ἅ.</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:495\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.495</biblScope></bibl></cit>, al.; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἅ. ἄμφω</quote_> <bibl n=\"urn:cts:greekLit:tlg0013.tlg002.perseus-grc1:15\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\">h.Cer.</title_> <biblScope TEIform=\"biblScope\">15</biblScope> </bibl> </cit>; <c