> <biblScope TEIform=\"biblScope\">2.26</biblScope></bibl>. </sense> <sense n=\"III\" id=\"n35078.2\" level=\"2\" opt=\"n\" TEIform=\"sense\"> of land in Egypt, <tr_ opt=\"n\" TEIform=\"tr\">release</tr_>, i.e. <tr_ opt=\"n\" TEIform=\"tr\">transfer to private tenure</tr_>, in <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <bibl n=\"http://www.trismegistos.org/text/28335\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ POxy.\">POxy.</a></title_> <biblScope TEIform=\"biblScope\">918xiii 9</biblScope> </bibl> <date TEIform=\"date\">(ii A.D.)</date>, etc. </sense> <sense n=\"2\" id=\"n35078.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">leave</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐναφῆκέν μου τὰ κτήματα ἀγεώργητα</quote_> <bibl n=\"Perseus:abo:pap,P.Cair.Masp.:5:20\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PMasp.\">PMasp.</a></title_> <biblScope TEIform=\"biblScope\">5.20</biblScope> </bibl> </cit> <date TEIform=\"date\">(vi A.D.)</date>. </sense> <sense n=\"IV\" id=\"n35078.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">permit</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">διατρέχειν τὸ πνεῦμα ἐν αὐτοῖς</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">τοῖς νεύροις</foreign>)<foreign lang=\"greek\" TEIform=\"foreign\">ἐ</foreign>. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Orib.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">37</biblScope></bibl>.</sense> </entryFree>"}]}