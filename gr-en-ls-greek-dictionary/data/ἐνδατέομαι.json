{"word":"ἐνδατέομαι","slug":"ἐνδατέομαι","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n35100\" key=\"e)ndate/omai\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἐνδᾰτέομαι</orth>, <sense id=\"n35100.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">divide</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">δὶς . . τοὔνομ᾽ ἐνδατούμενος</foreign> <tr_ opt=\"n\" TEIform=\"tr\">dividing</tr_> the name of Polynices (into <foreign lang=\"greek\" TEIform=\"foreign\">πολὺ νεῖκος</foreign>), <bibl n=\"urn:cts:greekLit:tlg0085.tlg004.perseus-grc1:578\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></title_> <biblScope TEIform=\"biblScope\">578</biblScope> </bibl> (v. Sch.); <foreign lang=\"greek\" TEIform=\"foreign\">ἐ. λόγους ὀνειδιστῆρας</foreign> <tr_ opt=\"n\" TEIform=\"tr\">distribute</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">fling about</tr_> reproaches, <bibl n=\"urn:cts:greekLit:tlg0006.tlg009.perseus-grc1:218\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ HF\">HF</a></title_> <biblScope TEIform=\"biblScope\">218</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n35100.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> c. acc. objecti, </sense> <sense n=\"a\" id=\"n35100.2\" level=\"4\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">speak of in detail</tr_>, i.e., in bad sense, <tr_ opt=\"n\" TEIform=\"tr\">reproach, revile</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">τὸ δυσπάρευνον λέκτρον ἐ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0011.tlg001.perseus-grc1:791\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"ti