form=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἦ τάχα</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:18:73\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">18.73</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἦ τε</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:13:211\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">13.211</biblScope> </bibl> </cit>: and to express doubt, <foreign lang=\"greek\" TEIform=\"foreign\">ἦ που</foreign>, <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">v.</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">ἦ που</ref> </xr> and <foreign lang=\"greek\" TEIform=\"foreign\">ποῦ</foreign>: esp. <foreign lang=\"greek\" TEIform=\"foreign\">ἦ μήν</foreign> used in oaths and asseverations, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:2:291\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">2.291</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:7:393\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">7.393</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:73\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">73</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:168\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">168</biblScope></bibl>, etc.; also <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἦ μάν</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:2:370\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=