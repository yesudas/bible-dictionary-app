inate, <bibl n=\"urn:cts:greekLit:tlg0059.tlg018:154b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Chrm.\">Chrm.</a></title_> <biblScope TEIform=\"biblScope\">154b</biblScope></bibl>, cf. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Plu.</author> <biblScope TEIform=\"biblScope\">2.513f</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n96174.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">παρὰ στάθμην</foreign> <tr_ opt=\"n\" TEIform=\"tr\">by the rule</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">εἶμι παρὰ ς. ὀρθὴν ὁδόν</quote_> <bibl n=\"Thgn. 945\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Thgn.\">Thgn.</a></author> <biblScope TEIform=\"biblScope\">945</biblScope></bibl></cit>, cf. <bibl n=\"Thgn. 543\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">543</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τέκτονος παρὰ ς. ἰόντος</quote_> <bibl n=\"urn:cts:greekLit:tlg0011.tlg008.perseus-grc1:474\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">474</biblScope> </bibl> </cit>; for <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:1045\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">1045</biblScope> </bibl> <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">v.</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">παρά</ref> </xr> c. <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:11:2\" default=\"NO\" TEI