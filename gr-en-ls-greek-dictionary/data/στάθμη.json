{"word":"στάθμη","slug":"στάθμη","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n96174\" key=\"sta/qmh\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"suff\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">στάθμ-η</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <sense id=\"n96174.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">carpenter's line</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">rule</tr_>, <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ξέσσε δ᾽ ἐπισταμένως</orth> <foreign lang=\"greek\" TEIform=\"foreign\">καὶ ἐπὶ στάθμην ἴθυνεν [δοῦρα]</foreign> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:5:245\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">5.245</biblScope></bibl>, cf.<bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:23:197\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">23.197</biblScope> </bibl>; [<foreign lang=\"greek\" TEIform=\"foreign\">πελέκεας] ἐπὶ ς. ἴθ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:21:121\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">21.121</biblScope> </bibl>; also <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">στάθμη δόρυ νήϊον ἐξιθύνει</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:15:410\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">15.410</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τόρνου καὶ στάθμης καὶ γνώμονος . . ἰθύτερον</quote_> <bibl n=\"Thgn. 805\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Thgn.\">Thgn.</a></author> <biblScope TEIform=\"biblScope\">805</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\"