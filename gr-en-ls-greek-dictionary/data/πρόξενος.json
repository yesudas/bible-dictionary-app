20</biblScope> </bibl> (lyr.), al., <bibl n=\"urn:cts:greekLit:tlg0019.tlg008.perseus-grc1:602\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></title_> <biblScope TEIform=\"biblScope\">602</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">φίλης γὰρ π. κατήνυσαν</foreign> at the house of a kind <tr_ opt=\"n\" TEIform=\"tr\">patroness,</tr_> i.e. Clytaemnestra, <bibl n=\"urn:cts:greekLit:tlg0011.tlg005.perseus-grc1:1451\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ El.\">El.</a></title_> <biblScope TEIform=\"biblScope\">1451</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">προξένῳ χρῆσθαί τινι</quote_> <bibl n=\"Eur. Fr. 721\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">721</biblScope></bibl></cit>. </sense> <sense n=\"III\" id=\"n88122.5\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adj.\">Adj.</a></pos>, <tr_ opt=\"n\" TEIform=\"tr\">assisting, relieving,</tr_> c. gen., <bibl n=\"urn:cts:greekLit:tlg0640.tlg001:3:72\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Alciphr.</author> <biblScope TEIform=\"biblScope\">3.72</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n88122.6\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">causing, producing,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">κακῶν, συμπτωμάτων, νόσων,</foreign> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ruf.\">Ruf.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr