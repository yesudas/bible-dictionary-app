{"word":"εἱαμενή","slug":"εἱαμενή","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n30821\" key=\"ei(amenh/\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">εἱᾰμενή</orth> or <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">εἰᾰμενή</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <sense id=\"n30821.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">a river-side pasture, meadow</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">ἐν εἱαμενῇ ἕλεος</foreign> in a marshy <tr_ opt=\"n\" TEIform=\"tr\">meadow</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:4:483\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">4.483</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λειμῶνες ὑπόδροσοι εἱαμεναί τε</quote_> <bibl n=\"urn:cts:greekLit:tlg0005.tlg001.perseus-grc1:25:16\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Theoc.\">Theoc.</a></author> <biblScope TEIform=\"biblScope\">25.16</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0533.tlg002:193\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Call.\">Call.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Dian.\">Dian.</a></title_> <biblScope TEIform=\"biblScope\">193</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:3:1202\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">3.1202</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0221.tlg001:138\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Euph.\">Euph.</a></author> <biblScope TEIform=\"biblScope\">138</biblScop