_> <tr_ opt=\"n\" TEIform=\"tr\">irrefutable,</tr_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg002.perseus-grc1:22a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ap.\">Ap.</a></title_> <biblScope TEIform=\"biblScope\">22a</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0059.tlg031:29b\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ti.\">Ti.</a></title_> <biblScope TEIform=\"biblScope\">29b</biblScope></bibl>. <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos> <foreign lang=\"greek\" TEIform=\"foreign\">-τως, λεγόμενον</foreign> <tr_ opt=\"n\" TEIform=\"tr\">without refutation</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">reply,</tr_> <bibl n=\"urn:cts:greekLit:tlg0007.tlg052:10\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Plu.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ CG\">CG</a></title_> <biblScope TEIform=\"biblScope\">10</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n8184.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of persons also, <tr_ opt=\"n\" TEIform=\"tr\">without trial,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀ. διαφυγεῖν</quote_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:6:53\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">6.53</biblScope></bibl></cit>.</sense> </entryFree>"}]}