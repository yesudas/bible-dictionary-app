Iform=\"bibl\">Sch. <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">3.158</biblScope></bibl>. </sense> <sense n=\"5\" id=\"n77875.6\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">to be marked with the</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">παράγραφος, κατὰ δύο παραγεγραμμένον ᾆσμα</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Heph.</author> </bibl> </cit> <tr_ opt=\"n\" TEIform=\"tr\">Poëm.</tr_> <bibl n=\"urn:cts:greekLit:tlg1402.tlg001:1\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1</biblScope></bibl>. </sense> <sense n=\"6\" id=\"n77875.7\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">bring to a close</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λόγον</quote_> <bibl n=\"urn:cts:greekLit:tlg1595.tlg080:22\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Phld.\">Phld.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Piet.\">Piet.</a></title_> <biblScope TEIform=\"biblScope\">22</biblScope></bibl></cit>. </sense> <sense n=\"II\" id=\"n77875.8\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, with <tns opt=\"n\" TEIform=\"tns\">pf.</tns> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, in various legal phrases: </sense> <sense n=\"1\" id=\"n77875.9\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">παραγράφεσθαι τὸν νόμον</foreign> <tr_ opt=\"n\" TEIform=\"tr\">h