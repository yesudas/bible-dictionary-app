 TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Vent.\">Vent.</a></title_> <biblScope TEIform=\"biblScope\">37</biblScope></bibl></cit>,<bibl n=\"urn:cts:greekLit:tlg0731.tlg002:39\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">39</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Eust.\">Eust.</a></author> </bibl> ad <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.P.\">D.P.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Prooem.\">Prooem.</a></title_> <biblScope TEIform=\"biblScope\">p.82</biblScope> </bibl> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ B.\">B.</a></author></bibl>, etc. [<foreign lang=\"greek\" TEIform=\"foreign\">τοῐ-</foreign> in <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:239\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">239</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:1400\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">1400</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0011.tlg004.perseus-grc1:435\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ OT\">OT</a></title_> <biblScope TEIform=\"biblScope\">435</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0011.tlg003.perseus-grc1:453\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Aj.\">Aj.</a></title_> <biblScope TEIform=\"biblScope\">453</biblScope> </bibl>; but not so freq. as in <foreign lang=\"greek\" TEIform=\"foreign\">τοιοῦτος.</f