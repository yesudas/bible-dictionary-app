ίτου ἀκτῇ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:14:429\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">14.429</biblScope> </bibl> </cit>:—<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἁ σῦριγξ εὐρῶτι παλύνεται</quote_> <bibl n=\"urn:cts:greekLit:tlg0005.tlg001.perseus-grc1:4:28\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Theoc.\">Theoc.</a></author> <biblScope TEIform=\"biblScope\">4.28</biblScope></bibl></cit>. </sense> <sense n=\"2\" id=\"n77049.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of liquids, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">κάρην ἱδρῶτι παλῦναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0084.tlg001:1049\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.P.\">D.P.</a></author> <biblScope TEIform=\"biblScope\">1049</biblScope></bibl></cit>. </sense> <sense n=\"3\" id=\"n77049.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">besmear</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἰξῷ</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\">AP</title_> <biblScope TEIform=\"biblScope\">10.11</biblScope> </bibl> </cit> (<bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Satyr.</author> </bibl>), cf. <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:3:1256\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">3.1256</biblScope> </bibl> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram> </gramGrp>).