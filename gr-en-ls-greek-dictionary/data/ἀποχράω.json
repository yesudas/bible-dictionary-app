21\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Xen.\">Xen.</a></title_> <biblScope TEIform=\"biblScope\">976b21</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n14310.5\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">to be contented with</tr_> a thing, c. dat., <foreign lang=\"greek\" TEIform=\"foreign\">ἀποχρεωμένων τούτοισι τῶν Μυσῶν</foreign> the Mysians <tr_ opt=\"n\" TEIform=\"tr\">being satisfied</tr_> therewith, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:37\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.37</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τοῖς ὀνόμασι μόνον</quote_> <bibl n=\"urn:cts:greekLit:tlg0014.tlg017.perseus-grc1:31\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">17.31</biblScope></bibl></cit>. </sense> <sense n=\"b\" id=\"n14310.6\" level=\"4\" opt=\"n\" TEIform=\"sense\"> impers., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὐκ ἀπεχρᾶτο μούνων Μήδων ἄρχειν</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:102\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.102</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀπεχρᾶτό σφι ἡσυχίην ἄγειν</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:8:14\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <