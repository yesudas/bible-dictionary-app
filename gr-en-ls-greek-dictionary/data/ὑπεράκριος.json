{"word":"ὑπεράκριος","slug":"ὑπεράκριος","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n107222\" key=\"u(pera/krios\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ὑπεράκριος</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ον</itype>, (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">ἄκρα</etym>) <sense id=\"n107222.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">over</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">beyond the heights,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">οἱ Ὑπεράκριοι,</foreign> <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">=</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">οἱ Διάκριοι</ref></xr>, <tr_ opt=\"n\" TEIform=\"tr\">the poor inhabitants of the Attic uplands beyond the heights (which bound the plain of Athens</tr_>), opp. to the richer classes of the plains and coasts (cf. <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πεδιακός</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg008.perseus-grc1:11\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11</biblScope></bibl></cit>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πάραλος</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg008.perseus-grc1:11\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11</biblScope> </bibl> </cit>), <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:59\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.59</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0081.tlg001:1:13\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.H.\">D.H.</a></author> <biblScope TEIform=\"biblScope\">1.13</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n107222.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <foreign lang