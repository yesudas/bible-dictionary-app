rm=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Eu.\">Eu.</a></title_> <biblScope TEIform=\"biblScope\">254</biblScope></bibl></cit>, <bibl n=\"urn:cts:greekLit:tlg0011.tlg005.perseus-grc1:1410\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ El.\">El.</a></title_> <biblScope TEIform=\"biblScope\">1410</biblScope></bibl>. </sense> <sense n=\"IV\" id=\"n17306.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">on the contrary,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἆρ᾽ ὀρθῶς . . ἢ αὖ;</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:468a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">468a</biblScope></bibl></cit>. </sense> <sense n=\"V\" id=\"n17306.5\" level=\"2\" opt=\"n\" TEIform=\"sense\"> of Place, <tr_ opt=\"n\" TEIform=\"tr\">backward,</tr_> only in the incorrect orthography <foreign lang=\"greek\" TEIform=\"foreign\">αὖ ἔρυσαν,</foreign> cf. <foreign lang=\"greek\" TEIform=\"foreign\">αὐερύω.</foreign>—Not placed first in a sentence. [<pron extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"pron\">ᾰυ</pron> before a vowel, <bibl n=\"urn:cts:greekLit:tlg0497.tlg001:153:3\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Pl.Com.</author> <biblScope TEIform=\"biblScope\">153.3</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Archestr.</author> </bibl> ap. <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:6:300e\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">6.300e</