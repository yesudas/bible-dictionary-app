t=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">20.348</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀνεμώλιον αὔ.</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:21:474\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">21.474</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">αὔ. ἄχθος ἀρούρης</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:20:379\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">20.379</biblScope></bibl></cit>, etc.; so, <tr_ opt=\"n\" TEIform=\"tr\">in vain,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὐκ αὔ. μυθήσομαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:14:151\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">14.151</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:2:342\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">2.342</biblScope></bibl>, etc. </sense> <sense n=\"II\" id=\"n18047.2\" level=\"2\" opt=\"n\" TEIform=\"sense\"> in reference to the past, <tr_ opt=\"n\" TEIform=\"tr\">just as before, as it was,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">ἧσθαι, κεῖσθαι,</foreign> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:133\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.133</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:338\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">18.338</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:20:130\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" hre