 <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ AJ\">AJ</a></title_> <biblScope TEIform=\"biblScope\">16.9.2</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">τῆς προθεσμίας παρελθούσης ῥύσια λαμβάνειν</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0526.tlg001.perseus-grc1:16:10:8\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">16.10.8</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ῥύσια καθέξοντες ἀνθ᾽ ὧν . . ἀφείλοντο . . Ῥωμαῖοι χρημάτων</quote_> <bibl n=\"urn:cts:greekLit:tlg0081.tlg001:5:33\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.H.\">D.H.</a></author> <biblScope TEIform=\"biblScope\">5.33</biblScope></bibl></cit>. </sense> <sense n=\"2\" id=\"n92851.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">stolen property taken back as compensation for the theft</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τοῦ ῥυσίου θ᾽ ἥμαρτε</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:535\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">535</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ῥυσίων ἐφάπτορες</foreign> laying hands on <tr_ opt=\"n\" TEIform=\"tr\">alleged stolen property</tr_>, <bibl n=\"urn:cts:greekLit:tlg0085.tlg001.perseus-grc1:728\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Supp.\">Supp.</a></title_> <biblScope TEIform=\"biblScope\">728</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg0085.tlg001.perseus-grc1:412\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">412</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n92851.3\" leve