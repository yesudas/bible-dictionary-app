s:greekLit:tlg0086.tlg038.perseus-grc1:1363a:23\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Rh.\">Rh.</a></title_> <biblScope TEIform=\"biblScope\">1363a23</biblScope> </bibl>); <foreign lang=\"greek\" TEIform=\"foreign\">ῥηΐδιόν τι ἔπος</foreign> a word <tr_ opt=\"n\" TEIform=\"tr\">easy to understand and follow</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:11:146\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">11.146</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg0013.tlg003.perseus-grc1:534\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ h.Ap.\">h.Ap.</a></title_> <biblScope TEIform=\"biblScope\">534</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">οἶμος ῥηϊδίη</foreign> an <tr_ opt=\"n\" TEIform=\"tr\">easy</tr_> road, <bibl n=\"urn:cts:greekLit:tlg0020.tlg002.perseus-grc1:292\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hes.\">Hes.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Op.\">Op.</a></title_> <biblScope TEIform=\"biblScope\">292</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ταχὺς γὰρ Ἅιδης ῥᾷστος ἀνδρὶ δυστυχεῖ</foreign>, i. e. least painful, <bibl n=\"urn:cts:greekLit:tlg0006.tlg005.perseus-grc1:1047\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Hipp.\">Hipp.</a></title_> <biblScope TEIform=\"biblScope\">1047</biblScope> </bibl>: c. <mood opt=\"n\" TEIform=\"mood\"><a class=\"S\" href=\"S:LSJ inf.\">inf.</a></mood>, <foreign lang=\"greek\" TEIform=\"foreign\">τάφρος περῆσαι ῥηϊδίη</foreign> <tr_ opt=\"n\" TEIform=\"tr\">easy</tr_> to pass over, <bibl n