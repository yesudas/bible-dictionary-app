bl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:6:37\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">6.37</biblScope> </bibl> </cit>: and with a neg., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἦ που . . γε . . οὐ δεῖ χρήσασθαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0027.tlg001.perseus-grc1:86\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ And.\">And.</a></author> <biblScope TEIform=\"biblScope\">1.86</biblScope></bibl></cit>. </sense> <sense n=\"II\" id=\"n47500.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> to make a hesitating suggestion, <tr_ opt=\"n\" TEIform=\"tr\">surely . . ?</tr_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:13:234\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">13.234</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:521\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">521</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0019.tlg011.perseus-grc1:970\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></title_> <biblScope TEIform=\"biblScope\">970</biblScope></bibl>.</sense> </entryFree>"}]}