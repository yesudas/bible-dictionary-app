{"word":"σηστός","slug":"σηστός","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n93895\" key=\"shsto/s\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">σηστός</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">σήθω</etym>) nickname of the courtesan Phryne, <sense id=\"n93895.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">the sifter</tr_>, because she drained her lovers of money, Herodic. ap. <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:13:591c\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">13.591c</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n93895.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">σηστὸν καρύων Ποντικῶν</foreign>, perh. name of a measure, <bibl n=\"Perseus:abo:pap,P.Cair.Zen.:13:22\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PCair.Zen.\">PCair.Zen.</a></title_> <biblScope TEIform=\"biblScope\">13.22</biblScope></bibl>, cf. <bibl n=\"Perseus:abo:pap,P.Cair.Zen.:12:9\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">12.9</biblScope> </bibl> <date TEIform=\"date\">(iii B.C.)</date>.</sense> </entryFree>"}]}