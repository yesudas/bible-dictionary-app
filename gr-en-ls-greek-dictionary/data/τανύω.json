eekLit:tlg0012.tlg002.perseus-grc1:15:283\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">15.283</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ἐτάνυσσε τράπεζαν</foreign> <tr_ opt=\"n\" TEIform=\"tr\">set out</tr_> a <tr_ opt=\"n\" TEIform=\"tr\">long</tr_> table, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:4:54\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">4.54</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:15:137\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">15.137</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">τ. τινὰ ἐν κονίῃς, ἐπὶ γαίῃ</foreign>, <tr_ opt=\"n\" TEIform=\"tr\">lay</tr_> one in the dust, <tr_ opt=\"n\" TEIform=\"tr\">stretch</tr_> him <tr_ opt=\"n\" TEIform=\"tr\">at his length</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:23:25\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">23.25</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:18:92\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">18.92</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ἕνα δρόμον τ</foreign>. <tr_ opt=\"n\" TEIform=\"tr\">form</tr_> one <tr_ opt=\"n\" TEIform=\"tr\">long</tr_> flight, of cranes, <bibl n=\"urn:cts:greekLit:tlg0653.tlg001.perseus-grc1:1011\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arat.\">Arat.</a></author> <biblScope TEIform=\"biblScope\">1011</biblScope> </bibl>:—<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">lie