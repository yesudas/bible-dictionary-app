/bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐπὶ χθονὶ κεῖτο τανυσθείς</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:20:483\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">20.483</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:13:392\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">13.392</biblScope></bibl>, etc. (so in <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">κεῖτο τανυσσάμενος</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:298\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">9.298</biblScope> </bibl> </cit>); also <foreign lang=\"greek\" TEIform=\"foreign\">τρίβος τετάνυστο</foreign> the path <tr_ opt=\"n\" TEIform=\"tr\">stretched away</tr_>, <bibl n=\"urn:cts:greekLit:tlg0005.tlg001.perseus-grc1:25:157\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Theoc.\">Theoc.</a></author> <biblScope TEIform=\"biblScope\">25.157</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">νὺξ τετάνυσται</quote_> <bibl n=\"urn:cts:greekLit:tlg0653.tlg001.perseus-grc1:557\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arat.\">Arat.</a></author> <biblScope TEIform=\"biblScope\">557</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">πλόος τ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:4:1583\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">4.1583</biblScope> </bibl> (dub. l.).</sense> </entryFree>"}]}