g=\"greek\" TEIform=\"foreign\">τοῦ καθήκοντος τοὺς ἀριθμούς</foreign> the <tr_ opt=\"n\" TEIform=\"tr\">sum total</tr_> of duty, <bibl n=\"urn:cts:greekLit:tlg0562.tlg001:3:1\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ M.Ant.\">M.Ant.</a></author> <biblScope TEIform=\"biblScope\">3.1</biblScope></bibl>. </sense> <sense n=\"5\" id=\"n15047.4\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">number, account,</tr_> as a mark of station, worth, rank, <foreign lang=\"greek\" TEIform=\"foreign\">μετ᾽ ἀνδρῶν ἵζει ἀριθμῷ</foreign> takes his place <tr_ opt=\"n\" TEIform=\"tr\">among</tr_> men, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:11:449\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">11.449</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">εἰς ἀνδρῶν μὲν οὐ τελοῦσιν ἀ.</quote_> <bibl n=\"Eur. Fr. 492\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">492</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">εἰς ἀ. τῶν κακῶν πεφύκαμεν</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg007.perseus-grc1:1186\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Hec.\">Hec.</a></title_> <biblScope TEIform=\"biblScope\">1186</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ξενίας ἀριθμῷ πρῶτ᾽ ἔχειν ἐμῶν φίλων</foreign> <tr_ opt=\"n\" TEIform=\"tr\">in regard of</tr_> friendship, ib.<bibl n=\"urn:cts:greekLit:tlg0006.tlg007.perseus-grc1:794\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">794</biblScope> </bibl>; 