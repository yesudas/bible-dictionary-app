5\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">1.585</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n44569.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of dates, <tr_ opt=\"n\" TEIform=\"tr\">without stones</tr_>, <bibl n=\"urn:cts:greekLit:tlg0086.tlg051:267\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">267</biblScope> </bibl>:—<bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Pythag.</author> </bibl> name for <foreign lang=\"greek\" TEIform=\"foreign\">θρίδαξ</foreign>, Lycusap. <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:2:69e\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">2.69e</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n44569.3\" level=\"2\" opt=\"n\" TEIform=\"sense\"> as <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adj.\">Adj.</a></pos>, <tr_ opt=\"n\" TEIform=\"tr\">watching the bed, sleepless</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λαμπάδες εὐνούχοισιν ὄμμασιν</quote_> <bibl n=\"urn:cts:greekLit:tlg0011.tlg008.perseus-grc1:789\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">789</biblScope></bibl></cit>.</sense> </entryFree>"}]}