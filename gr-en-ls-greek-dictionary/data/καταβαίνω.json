lScope> </bibl> </cit>), <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:94\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.94</biblScope></bibl>, etc.; also from Athens, <foreign lang=\"greek\" TEIform=\"foreign\">κ. ἐς Πειραιᾶ, ἐς λιμένα</foreign>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:327a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">327a</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg006.perseus-grc1:142a\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tht.\">Tht.</a></title_> <biblScope TEIform=\"biblScope\">142a</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n53651.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">go down into the scene of contest</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">γυμνὸν ἐπὶ στάδιον κ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0033.tlg002.perseus-grc1:11:49\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ P.\">P.</a></title_> <biblScope TEIform=\"biblScope\">11.49</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">κ. ἐπ᾽ αὐτὸ τοῦτο</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">τὸ ἀεθλεύειν</foreign>) <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:5:22\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">5.22</biblScope> </bibl>: abs., <abbr TEIform=\"abbr\">=</abbr> Lat. <tr_ opt=\"n\" TEIform=\"tr\">in certamen descendere</tr_>, <bibl n=\"urn:cts:greekLit:tlg0033.tlg003.perseus-grc1:3:42\" default=\"NO\" TEIf