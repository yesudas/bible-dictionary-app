\"> <quote_ lang=\"greek\" TEIform=\"quote\">κολλητὰς ἐπέθηκα θύρας</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:23:194\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">23.194</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">θύρας ἐπέθηκε φαεινάς</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:21:45\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">21.45</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">θυρεὸν μέγαν</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:240\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9.240</biblScope> </bibl> </cit> (v. infr. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ B.\">B.</a></author> <biblScope TEIform=\"biblScope\">11</biblScope> </bibl>). </sense> <sense n=\"2\" id=\"n41357.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">set</tr_> a seal <tr_ opt=\"n\" TEIform=\"tr\">on</tr_>, <bibl n=\"http://www.trismegistos.org/text/9085\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ BGU\">BGU</a></title_> <biblScope TEIform=\"biblScope\">361 iii 22</biblScope> </bibl> <date TEIform=\"date\">(ii A.D.)</date> ; <tr_ opt=\"n\" TEIform=\"tr\">apply</tr_> a pessary, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hp.\">Hp.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Steril.\">Steril.</a></title_> <biblScope TEIform=\"biblScope\">214</biblScope> </bibl> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Pass.\">Pass.</a></gram> </gramGrp>) ; a cupping instrument, <bibl n=\"urn:cts:greekLit:tlg0565.tlg001:2:11\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Sor.</author> <biblScope TEIform=\"b