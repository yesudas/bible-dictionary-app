=\"greek\" TEIform=\"foreign\">πῦρ πνεόντων χ. ἄστρων,</foreign> of Dionysus, <bibl n=\"urn:cts:greekLit:tlg0011.tlg002.perseus-grc1:1147\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ant.\">Ant.</a></title_> <biblScope TEIform=\"biblScope\">1147</biblScope> </bibl> (lyr.); <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">χ. δελφίνων</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg014.perseus-grc1:1454\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Hel.\">Hel.</a></title_> <biblScope TEIform=\"biblScope\">1454</biblScope> </bibl> </cit> (lyr.). </sense> <sense n=\"II\" id=\"n114432.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> at Athens and elsewhere, <tr_ opt=\"n\" TEIform=\"tr\">one who defrays the costs for producing a chorus,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">χορηγῶν ἀποδεικνυμένων ἑκατέρῃ τῶν δαιμόνων δέκα ἀνδρῶν</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:5:83\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">5.83</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">χορηγὸν καταστῆσαί τινα</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ IG\">IG</a></title_> <biblScope TEIform=\"biblScope\">22.141.34</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">χ. κατεστάθην εἰς Θαργήλια</quote_> <bibl n=\"urn:cts:greekLit:tlg0028.tlg006.perseus-grc1:11\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Antipho\">Antipho</a></author> <biblScope TEIform=\"biblScope\">6.11</biblScope> </bibl> </cit>; <cit TEIfor