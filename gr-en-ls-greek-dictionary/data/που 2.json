Scope\">522</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:362d\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">362d</biblScope></bibl>, etc.; <foreign lang=\"greek\" TEIform=\"foreign\">οὐ δήπου</foreign> adds a shade of suspicion, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὐ δήπου Στράτων;</quote_> <bibl n=\"urn:cts:greekLit:tlg0019.tlg001.perseus-grc1:122\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ach.\">Ach.</a></title_> <biblScope TEIform=\"biblScope\">122</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0019.tlg006.perseus-grc1:269\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Av.\">Av.</a></title_> <biblScope TEIform=\"biblScope\">269</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg011.perseus-grc1:194b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Smp.\">Smp.</a></title_> <biblScope TEIform=\"biblScope\">194b</biblScope> </bibl>: for <foreign lang=\"greek\" TEIform=\"foreign\">δήπου, ἦπου,</foreign> <abbr TEIform=\"abbr\">v.</abbr> sub vocc.—In late writers (<bibl n=\"urn:cts:greekLit:tlg0527.tlg006:2:5\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ LXX\">LXX</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Jo.\">Jo.</a></title_> <biblScope TEIform=\"biblScope\">2.5</biblScope></bibl>, al., <bibl n=\"urn:cts:greekLit:tlg0031.tlg004.perseus-grc1:7:35\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ev.Jo.\">Ev.Jo.</a></title_> <biblScope T