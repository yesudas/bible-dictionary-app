gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Att.\">Att.</a></gram> </gramGrp> Prose. </sense> <sense n=\"II\" id=\"n96017.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">dust</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῆς χαμᾶθεν σποδοῦ</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:4:172\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">4.172</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">μετρεῖν τὴν ς</foreign>., of labour in vain, <bibl n=\"urn:cts:greekLit:tlg0074.tlg-02:3:26:17\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Arr.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Epict.\">Epict.</a></title_> <biblScope TEIform=\"biblScope\">3.26.17</biblScope></bibl>. </sense> <sense n=\"III\" id=\"n96017.2\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">oxide</tr_> of certain metals, <foreign lang=\"greek\" TEIform=\"foreign\">ς. Κυπρίη</foreign> copper <tr_ opt=\"n\" TEIform=\"tr\">oxide</tr_>, <bibl n=\"urn:cts:greekLit:tlg0627.tlg036:1:104\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hp.\">Hp.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Mul.\">Mul.</a></title_> <biblScope TEIform=\"biblScope\">1.104</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ς. Ἰλλυριῶτις</quote_> <bibl n=\"urn:cts:greekLit:tlg0627.tlg028.perseus-grc1:13\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ulc.\">Ulc.</a></title_> <biblScope TEIform=\"biblScope\">13</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ς. χ