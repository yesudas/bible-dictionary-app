{"word":"σφαραγέομαι","slug":"σφαραγέομαι","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n101621\" key=\"sfarage/omai\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">σφᾰρᾰγ-έομαι</orth>, <sense id=\"n101621.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">burst with a noise, crackle, sputter</tr_>, as liquids when thrown upon the fire, <foreign lang=\"greek\" TEIform=\"foreign\">σφαραγεῦντο δέ οἱ πυρὶ ῥίζαι</foreign> the roots of his eye <tr_ opt=\"n\" TEIform=\"tr\">crackled</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">hissed</tr_> (when Odysseus burnt them with the hot stake), <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:390\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">9.390</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n101621.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">groan with fulness, to be full to bursting</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">οὔθατα γὰρ σφαραγεῦντο</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:440\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">440</biblScope></bibl>.</sense> </entryFree>"}]}