lScope\">2.19</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">τῇ αὐτῇ ἰ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:3:62\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">3.62</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:6:76\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">6.76</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">οὐκ ἐν ταῖς αὐταῖς ἰ</foreign>. not in the same <tr_ opt=\"n\" TEIform=\"tr\">relations</tr_>, <bibl n=\"urn:cts:greekLit:tlg0010.tlg014.perseus-grc1:44\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Isoc.\">Isoc.</a></author> <biblScope TEIform=\"biblScope\">3.44</biblScope> </bibl>: <foreign lang=\"greek\" TEIform=\"foreign\">εἰς μίαν τινὰ ἰ</foreign>. into one <tr_ opt=\"n\" TEIform=\"tr\">kind of existence</tr_>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg006.perseus-grc1:184d\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tht.\">Tht.</a></title_> <biblScope TEIform=\"biblScope\">184d</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἄλλη ἰ. πολιτείας</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:544c\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">544c</biblScope></bibl></cit>, etc.; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀγοραίας . . ἰδέας τοῦ βίου</quote_> <bibl n=\"urn:cts:greekLit:tlg0537.tlg003:196\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Epicur.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.