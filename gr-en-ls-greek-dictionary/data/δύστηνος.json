20\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.H.\">D.H.</a></author> <biblScope TEIform=\"biblScope\">6.20</biblScope></bibl></cit>. <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos>, <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"comp\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Sup.\">Sup.</a></gram> </gramGrp> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">δυστανοτάτως γηράσκω</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg008.perseus-grc1:967\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Supp.\">Supp.</a></title_> <biblScope TEIform=\"biblScope\">967</biblScope> </bibl> </cit> (lyr.). </sense> <sense n=\"II\" id=\"n29524.3\" level=\"2\" opt=\"n\" TEIform=\"sense\"> after <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Hom.</author></bibl>, in moral sense, <tr_ opt=\"n\" TEIform=\"tr\">wretched</tr_>, <bibl n=\"urn:cts:greekLit:tlg0011.tlg005.perseus-grc1:121\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ El.\">El.</a></title_> <biblScope TEIform=\"biblScope\">121</biblScope> </bibl> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"comp\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Sup.\">Sup.</a></gram></gramGrp>, lyr.), <bibl n=\"urn:cts:greekLit:tlg0011.tlg006.perseus-grc1:1016\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ph.\">Ph.</a></title_> <biblScope TEIform=\"biblScope\">1016</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λόγοι</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg009.perseus-grc1:1346\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></