> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">τί μέμονας</foreign>; what <tr_ opt=\"n\" TEIform=\"tr\">wishest</tr_> thou ? <bibl n=\"urn:cts:greekLit:tlg0085.tlg004.perseus-grc1:686\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></title_> <biblScope TEIform=\"biblScope\">686</biblScope> </bibl> (lyr.): c. gen., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">μεμαυῖ) ἔριδος καὶ ἀϋτῆς</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:5:732\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">5.732</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">μεμαότε θούριδος ἀλκῆς</foreign> <tr_ opt=\"n\" TEIform=\"tr\">mindful</tr_> of . . , <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:13:197\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">13.197</biblScope> </bibl> (cf. <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">μεδώμεθα θούριδος ἀλκῆς</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:5:718\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">5.718</biblScope> </bibl> </cit>); <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἦ τινα καὶ Δαναῶν, ἀλκῆς μάλα περ μεμαῶτα, σχήσω ἀμυνέμεναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:17:181\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">17.181</biblScope> </bibl> </cit> (unless <foreign lang=\"greek\" TEIform=\"foreign\">ἀλκῆς</foreign> goes only with <foreign lang=\"greek\" TEIform=\"foreign\">σχήσω</foreign>), cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:9:655\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9.655</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:20:256\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">20.256</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:22:172\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">22.172</biblScope> </bibl>: abs., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">διχθὰ δέ μοι κραδίη μέμονε</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:16:435\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">16.435</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">δίδυμα μέμονε φρήν</quote_> <bibl n=\"urn:cts:greekLit:tlg0006.tlg013.perseus-grc1:655\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ IT\">IT</a></title_> <biblScope TEIform=\"biblScope\">655</biblScope> </bibl> </cit> (lyr.).</sense> </entryFree>"}]}