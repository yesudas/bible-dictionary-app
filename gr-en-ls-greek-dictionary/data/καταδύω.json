orm=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ V.\">V.</a></title_> <biblScope TEIform=\"biblScope\">140</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n53956.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">go down, plunge into</tr_>, c. acc., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">καταδῦναι ὅμιλον</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:10:231\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">10.231</biblScope></bibl></cit>, etc.; <foreign lang=\"greek\" TEIform=\"foreign\">κατεδύσετο πουλὺν ὅμιλον</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:517\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">517</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">καταδύσεο μῶλον Ἄρηος</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:134\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">18.134</biblScope> </bibl> </cit>; so <foreign lang=\"greek\" TEIform=\"foreign\">μάχην, δόμον, πόλιν καταδύμεναι</foreign>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:3:241\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3.241</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:8:375\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">8.375</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:4:246\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">4.246</biblScope> </bibl>: folld. by Prep., <foreign lang=\"greek\" TEIform=\"foreign\">μυῖαι καδδῦσαι</foreign> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\"