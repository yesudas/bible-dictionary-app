ibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:8:22\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">8.22</biblScope> </bibl>: c. acc. cogn., <foreign lang=\"greek\" TEIform=\"foreign\">ἄλλα νοέειν</foreign> <tr_ opt=\"n\" TEIform=\"tr\">to be</tr_> other wise <tr_ opt=\"n\" TEIform=\"tr\">minded,</tr_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:7:168\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">7.168</biblScope> </bibl>; also <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">εἰπὲ δ᾽ ᾗ νοεῖς</quote_> <bibl n=\"urn:cts:greekLit:tlg0011.tlg001.perseus-grc1:1135\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tr.\">Tr.</a></title_> <biblScope TEIform=\"biblScope\">1135</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0011.tlg005.perseus-grc1:1435\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ El.\">El.</a></title_> <biblScope TEIform=\"biblScope\">1435</biblScope> </bibl>: <mood opt=\"n\" TEIform=\"mood\"><a class=\"S\" href=\"S:LSJ part.\">part.</a></mood> <foreign lang=\"greek\" TEIform=\"foreign\">νοέων, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">έουσα</itype>,</foreign> <tr_ opt=\"n\" TEIform=\"tr\">wary, discreet,</tr_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:577\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">1.577</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὴν μέν κεν ἐπαινέσσειε νοήσας</quote_> <bibl n=\"urn:cts:greekLit:tlg0020.tlg002.perseus-grc1:12\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"auth