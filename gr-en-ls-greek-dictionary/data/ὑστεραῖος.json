lScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">66.19</biblScope> </bibl>; also <foreign lang=\"greek\" TEIform=\"foreign\">ἐς τὴν ὑστεραίην</foreign>(<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">-αν</etym>)<foreign lang=\"greek\" TEIform=\"foreign\">ἐλθεῖν, ἀναβαλέσθαι,</foreign> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:4:113\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">4.113</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0014.tlg021.perseus-grc1:84\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">21.84</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐν τῇ ὑ.</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg022:318a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Prt.\">Prt.</a></title_> <biblScope TEIform=\"biblScope\">318a</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">τῆς ὑ. καὶ ἐπὶ τῆς ἄλλης ὑστέρης</foreign> on the <tr_ opt=\"n\" TEIform=\"tr\">morrow</tr_> and the day following, <bibl n=\"urn:cts:greekLit:tlg0719.tlg003.perseus-grc1:2:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Aret.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ CA\">CA</a></title_> <biblScope TEIform=\"biblScope\">2.2</biblScope> </bibl>: c. gen., <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇ ὑ. τῶν μυστηρίων</quote_> <bibl n=\"urn:cts:greekLit:tlg0027.tlg001.perseus-grc1:111\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ And.\">And.</a></author> <biblScope TEIform=\"biblScope\">1.111</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇ ὑ. τῆς μάχης</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg028.perseus-grc1:240c\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Mx.\">Mx.</a></title_> <biblScope TEIform=\"biblScope\">240c</biblScope> </bibl> </cit>: folld. by <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἤ, τῇ ὑ. ἢ ᾗ ἂν ἔλθῃ</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg003.perseus-grc1:44a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Cri.\">Cri.</a></title_> <biblScope TEIform=\"biblScope\">44a</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇ ὑ. ἢ ᾗ ἔθυεν</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg011.perseus-grc1:173a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Smp.\">Smp.</a></title_> <biblScope TEIform=\"biblScope\">173a</biblScope> </bibl> </cit>; and prob. <foreign lang=\"greek\" TEIform=\"foreign\">ἤ</foreign> should be inserted in the foll. places, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇ ὑ. ᾗ ἐθάπτετο</quote_> <bibl n=\"urn:cts:greekLit:tlg0028.tlg006.perseus-grc1:37\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Antipho\">Antipho</a></author> <biblScope TEIform=\"biblScope\">6.37</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">τῇ ὑ. ᾗ ἂν προθῶνται</foreign> Lex ap. <bibl n=\"urn:cts:greekLit:tlg0014.tlg043.perseus-grc1:62\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">43.62</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n109730.1\" level=\"2\" opt=\"n\" TEIform=\"