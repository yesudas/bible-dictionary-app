{"word":"ἐγκόμβωμα","slug":"ἐγκόμβωμα","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n30367\" key=\"e)gko/mbwma\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"suff\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἐγκόμβ-ωμα</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ατος</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">τό</gen>, a sort of <sense id=\"n30367.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">frock</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">apron</tr_>, worn esp. by slaves to keep the <foreign lang=\"greek\" TEIform=\"foreign\">ἐξωμίς</foreign> clean, <bibl n=\"urn:cts:greekLit:tlg0561.tlg001.perseus-grc1:2:33\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Longus\">Longus</a></author> <biblScope TEIform=\"biblScope\">2.33</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0542.tlg001:4:119\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Poll.</author> <biblScope TEIform=\"biblScope\">4.119</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Thd.\">Thd.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Is.\">Is.</a></title_> <biblScope TEIform=\"biblScope\">3.20</biblScope></bibl>, cf. Varroap.Non.<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">p.870</biblScope> </bibl> L.</sense> </entryFree>"}]}