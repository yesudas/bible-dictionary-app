{"word":"εἰκαδισταί","slug":"εἰκαδισταί","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n30910\" key=\"ei)kadistai/\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">εἰκᾰδισταί</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ῶν</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">οἱ</gen>, epith. of the Epicureans, because they commemorated their founder's death <sense id=\"n30910.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">on the twentieth</tr_> (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">εἰκάς</etym>) of Gamelion, <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:7:298d\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">7.298d</biblScope></bibl>.</sense> </entryFree>"}]}