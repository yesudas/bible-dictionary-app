2.tlg001.perseus-grc1:58\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">58</biblScope> </bibl> B.C.), which are inscribed <tr_ opt=\"n\" TEIform=\"tr\">Ypsae, BMus.Cat.Republ.Coins, Plate</tr_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:48\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">48</biblScope> </bibl> Nos.<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:2\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:3\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:4\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">4</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:5\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">5</biblScope></bibl>, but <tr_ opt=\"n\" TEIform=\"tr\">Hupsae,</tr_> Nos.<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:13\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">13</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:14\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">14</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\">Plate</title_> <biblScope TEIform=\"biblScope\">123</biblScope> </bibl> Nos.<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">7</biblScope></bibl>,<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">8</biblScope></bibl>,<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9</biblScope></bibl>.</sense> </entryFree>"}]}