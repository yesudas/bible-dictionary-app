> <author TEIform=\"author\">Erot.</author> </bibl> (citing Euripides); <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">=</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">στρογγύλος</ref></xr>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl>)</sense> </entryFree>"}]}