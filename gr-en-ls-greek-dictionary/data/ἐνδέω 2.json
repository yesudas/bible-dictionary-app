form=\"biblScope\">432d</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἕως γ᾽ ἂν μηδὲν ἐνδέῃ τοῦ ποιμενικὴ εἶναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:345d\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">345d</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:529d\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">529d</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg004.perseus-grc1:74d\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Phd.\">Phd.</a></title_> <biblScope TEIform=\"biblScope\">74d</biblScope> </bibl>:—also in <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">to be in want of, lack</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">δριμύτητος ἐνδεῖται</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg008.perseus-grc1:311a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Plt.\">Plt.</a></title_> <biblScope TEIform=\"biblScope\">311a</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0032.tlg007.perseus-grc1:2:2:26\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ X.\">X.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Cyr.\">Cyr.</a></title_> <biblScope TEIform=\"biblScope\">2.2.26</biblScope></bibl>, etc.:—so in <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ aor.\">aor.</a></tns> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" hre