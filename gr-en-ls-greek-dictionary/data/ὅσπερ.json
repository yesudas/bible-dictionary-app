S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">3.1098</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τοῦπερ</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg002.perseus-grc1:779\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pers.\">Pers.</a></title_> <biblScope TEIform=\"biblScope\">779</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τῇπερ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:24:603\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">24.603</biblScope></bibl></cit>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:30\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.30</biblScope> </bibl> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τοίπερ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:13:130\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">13.130</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τάπερ</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg006.perseus-grc1:418\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ch.\">Ch.</a></title_> <biblScope TEIform=\"biblScope\">418</biblScope> </bibl> </cit> (lyr.), <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:3:16\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">3.16</biblSco