{"word":"οὐκ 2","slug":"οὐκ 2","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n75807\" key=\"ou)k2\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">οὐκ ἄρα,</orth> <pos opt=\"n\" TEIform=\"pos\"><a class=\"S\" href=\"S:LSJ Adv.\">Adv.</a></pos> <sense id=\"n75807.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">so not, not then</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὐκ ἄρα σοί γε πατὴρ ἦν . . Πηλεύς</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:16:33\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">16.33</biblScope></bibl></cit>. </sense> <sense n=\"II\" id=\"n75807.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> in questions, <foreign lang=\"greek\" TEIform=\"foreign\">οὐκ ἄρ᾽ ἔμελλες οὐδὲ θανὼν λήσεσθαι . . χόλου</foreign> <tr_ opt=\"n\" TEIform=\"tr\">; so not</tr_> even in death wert thou to forget thine anger? <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:11:553\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">11.553</biblScope></bibl>.</sense> </entryFree>"}]}