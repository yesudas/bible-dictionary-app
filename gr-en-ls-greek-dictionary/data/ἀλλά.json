_ lang=\"greek\" TEIform=\"quote\">ἀ. μὲν δὴ καὶ αὐτός</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg006.perseus-grc1:143b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Tht.\">Tht.</a></title_> <biblScope TEIform=\"biblScope\">143b</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0011.tlg005.perseus-grc1:103\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ S.\">S.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ El.\">El.</a></title_> <biblScope TEIform=\"biblScope\">103</biblScope></bibl>. </sense> <sense n=\"IV\" id=\"n4357.23\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <abbr TEIform=\"abbr\">=</abbr> <tr_ opt=\"n\" TEIform=\"tr\">et quidem</tr_>, <bibl n=\"urn:cts:greekLit:tlg4019.tlg003:1:13\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Olymp.\">Olymp.</a></author> <title_ TEIform=\"title\">in Mete.</title_> <biblScope TEIform=\"biblScope\">1.13</biblScope></bibl>, al.</sense> </entryFree>"}]}