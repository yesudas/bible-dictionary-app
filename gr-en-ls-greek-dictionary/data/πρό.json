lg001.perseus-grc1:7:152\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">7.152</biblScope> </bibl> (so, <tr_ opt=\"n\" TEIform=\"tr\">in order to avoid,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">π. τοῦ δεινοτάτου</quote_> <bibl n=\"urn:cts:greekLit:tlg0014.tlg054.perseus-grc1:19\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.\">D.</a></author> <biblScope TEIform=\"biblScope\">54.19</biblScope> </bibl> </cit>); <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πᾶν π. τοῦ δουλεῦσαι ἐπεξελθεῖν</quote_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:5:100\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">5.100</biblScope></bibl></cit>, cf.<bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:4:59\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">4.59</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ἑλέσθαι, αἱρεῖσθαι,</foreign> or <foreign lang=\"greek\" TEIform=\"foreign\">κρῖναί τι π. τινός</foreign> to choose one <tr_ opt=\"n\" TEIform=\"tr\">before</tr_> another, <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:5:36\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">5.36</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:366b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">366b</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg010:57e\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Phlb.\">Phlb.</a></title_>