.\">Mem.</a></title_> <biblScope TEIform=\"biblScope\">3.12.1</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0032.tlg002.perseus-grc1:3:12:5\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3.12.5</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n102000.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">body</tr_>, opp. <tr_ opt=\"n\" TEIform=\"tr\">spirit</tr_> (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">εἴδωλον</etym>), <bibl n=\"urn:cts:greekLit:tlg0033.tlg005:131\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">131</biblScope> </bibl>; opp. <tr_ opt=\"n\" TEIform=\"tr\">soul</tr_> (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">ψυχή</etym>), <bibl n=\"urn:cts:greekLit:tlg0059.tlg023:493a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Grg.\">Grg.</a></title_> <biblScope TEIform=\"biblScope\">493a</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0059.tlg004.perseus-grc1:91d\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Phd.\">Phd.</a></title_> <biblScope TEIform=\"biblScope\">91d</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">τὰ τοῦ ς. ἔργα</foreign> <tr_ opt=\"n\" TEIform=\"tr\">bodily</tr_> labours, <bibl n=\"urn:cts:greekLit:tlg0032.tlg002.perseus-grc1:2:8:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ X.\">X.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Mem.\">Mem.</a></title_> <biblScope TEIform=\"biblScope\">2.8.2</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">αἱ τοῦ ς. ἡδοναί, αἱ κατὰ τὸ ς. ἡδ</foreign>., ib.<bibl n=\"urn:cts:greekLit:tlg0032.tlg002.perseus-grc1:1:5:6\" def