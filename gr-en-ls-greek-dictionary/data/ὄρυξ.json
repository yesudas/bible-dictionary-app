{"word":"ὄρυξ","slug":"ὄρυξ","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n75427\" key=\"o)/ruc\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ὄρυξ</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ῠγος</itype><foreign lang=\"greek\" TEIform=\"foreign\">, ὁ</foreign> (<orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ὄρυγξ</orth> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl>), <sense id=\"n75427.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">pickaxe</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">any sharp iron tool for digging,</tr_> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">AP</author> <biblScope TEIform=\"biblScope\">6.297</biblScope> </bibl> (<bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Phan.\">Phan.</a></author> </bibl>). </sense> <sense n=\"II\" id=\"n75427.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> a kind of <tr_ opt=\"n\" TEIform=\"tr\">gazelle</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">antelope,</tr_> in Egypt and Libya, so called from its <tr_ opt=\"n\" TEIform=\"tr\">pointed horns, beisa, Oryx leucoryx,</tr_> described as <foreign lang=\"greek\" TEIform=\"foreign\">μονόκερως,</foreign> <bibl n=\"urn:cts:greekLit:tlg0086.tlg014:499b:20\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ HA\">HA</a></title_> <biblScope TEIform=\"biblScope\">499b20</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0086.tlg030:663a:23\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PA\">PA</a></title_> <biblScope TEIform=\"biblScope\">663a23</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg1240.tlg001:2\" default=\"NO