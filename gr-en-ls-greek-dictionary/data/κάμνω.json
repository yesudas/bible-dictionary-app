-grc1:216\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">216</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐπεὶ πάνθ᾽ ὅπλα κάμε</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:614\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">18.614</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">σκῆπτρον . . , τὸ μὲν Ἥφαιστος κάμε τεύχων</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:2:101\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">2.101</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:8:195\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">8.195</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">κ. νῆας</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:126\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">9.126</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πέπλον</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:5:338\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">5.338</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:15:105\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">15.105</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἵππον</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:11:523\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11.523</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">λέχος</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:23:189\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">23.189</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ἄστυ</foreign> <tr_ opt=\"n\" TEIform=\"tr\">build</tr_>, <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:1:1322\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">1.1322</biblScope> </bibl>: also in <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ aor.\">aor.</a></tns> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἱρόν</quote_> <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:718\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">2.718</biblScope></bibl></cit>. </sense> <sense n=\"2\" id=\"n52995.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ aor.\">aor.</a></tns> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">win by toil</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">τὰς</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">γυναῖκας</foreign>)<cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">αὐτοὶ καμόμεσθα βίηφί τε δουρί τε μακρῷ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:341\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">18.341</biblScope></bibl></cit>. </sense> <sense n=\"3\" id=\"n52995.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ aor.\">aor.</a></tns> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"voice\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></gram></gramGrp>, <tr_ opt=\"n\" TEIform=\"tr\">labour, till</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οἵ κέ σφιν καὶ νῆσον . . ἐκάμοντο</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:9:130\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">9.130</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οἴκους</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Philet.\">Philet.</a></author> <biblScope TEIform=\"biblScope\">8</biblScope></bibl></cit>. </sense> <sense n=\"II\" id=\"n52995.4\" level=\"2\" opt=\"n\" TEIform=\"sense\"> intr., <tr_ opt=\"n\" TEIform=\"tr\">toil, labour</tr_>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">τινι</itype> <tr_ opt=\"n\" TEIform=\"tr\">for</tr_> one, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:14:65\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">14.65</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὑπὲρ τῆς πόλεως</quote_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:2:41\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">2.41</biblScope> </bibl> </cit>: then, from the effect of continued work, <tr_ opt=\"n\" TEIform=\"tr\">to be weary</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀνδρὶ δὲ κεκμηῶτι μένος μέγα οἶνος ἀέξει</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:6:261\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"auth