{"word":"ἀπόκλεισις","slug":"ἀπόκλεισις","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n12848\" key=\"a)po/kleisis\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἀπό-κλεισις</orth> or <orth extent=\"suff\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">ἀπό-κλησις</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">εως</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">ἀποκλείω</etym>) <sense id=\"n12848.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">a shutting up,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">ἀ. μου τῶν πυλῶν</foreign> <tr_ opt=\"n\" TEIform=\"tr\">a shutting</tr_> the gates <tr_ opt=\"n\" TEIform=\"tr\">against</tr_> me, <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:4:85\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">4.85</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n12848.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">a shutting out,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">ἀποκλῄσεις γίγνεσθαι</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">ἔμελλον</foreign>) there would be <tr_ opt=\"n\" TEIform=\"tr\">a complete stoppage to their works,</tr_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:6:99\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">6.99</biblScope></bibl>.</sense> </entryFree>"}]}