{"word":"συνοδοντίς","slug":"συνοδοντίς","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n100763\" key=\"sunodonti/s\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">συνοδοντίς</orth>, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ίδος</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">συνόδους</etym>) a large kind of <sense id=\"n100763.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">tunny</tr_>, <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:7:312b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">7.312b</biblScope></bibl>. </sense> <sense n=\"b\" id=\"n100763.1\" level=\"4\" opt=\"n\" TEIform=\"sense\"> a fish of the Nile, Diph.Siph.ib.<bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:8:356f\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">8.356f</biblScope> </bibl>: hence <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">συνοδοντῖτις</orth> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">λίθος</foreign>), <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ιδος</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, <tr_ opt=\"n\" TEIform=\"tr\">a stone found in its head</tr_>, <bibl n=\"urn:cts:latinLit:phi0978.phi001:37:182\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Plin.\">Plin.</a></author> <title_ TEIform=\"title\">HN</title_> <biblScope TEIform=\"biblScope\">37.182</biblScope></bibl>.</sense> </entryFree>"}]}