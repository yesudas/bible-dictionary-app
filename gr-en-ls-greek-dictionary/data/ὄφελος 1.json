"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hp.\">Hp.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Vict.\">Vict.</a></title_> <biblScope TEIform=\"biblScope\">3.69</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τί τῆς εὐμορφίας ὄ.</quote_> <tr_ opt=\"n\" TEIform=\"tr\">;</tr_> <bibl n=\"Eur. Fr. 548\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">548</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ἐλευθερίας οὐδὲν ὄ</foreign>. <bibl n=\"urn:cts:greekLit:tlg0027.tlg004.perseus-grc1:17\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ And.\">And.</a></author> <biblScope TEIform=\"biblScope\">4.17</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐάν τι ἡμῶν ὡς νομοθετῶν ὄ. ᾖ</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg030.perseus-grc1:530c\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ R.\">R.</a></title_> <biblScope TEIform=\"biblScope\">530c</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἀνὴρ ὅτου τι καὶ σμικρὸν ὄ. ἐστιν</quote_> <bibl n=\"urn:cts:greekLit:tlg0059.tlg002.perseus-grc1:28b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ap.\">Ap.</a></title_> <biblScope TEIform=\"biblScope\">28b</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">γεωργοῦ ἀργοῦ οὐδὲν ὄφελος</quote_> <bibl n=\"urn:cts:greekLit:tlg0032.tlg007.perseus-grc1:1:6:18\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><