 default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Nicom.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></title_> <biblScope TEIform=\"biblScope\">1.19</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg4066.tlg003:374\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Dam.\">Dam.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">374</biblScope> </bibl>; but simply the <tr_ opt=\"n\" TEIform=\"tr\">second-named term in a ratio,</tr_> <bibl n=\"urn:cts:greekLit:tlg4034.tlg001:16:14\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Mich.</author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ in EN\">in EN</a></title_> <biblScope TEIform=\"biblScope\">16.14</biblScope></bibl>.</sense> </entryFree>"}]}