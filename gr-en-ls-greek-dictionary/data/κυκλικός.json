l default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">237</biblScope></bibl>. </sense> <sense n=\"4\" id=\"n60621.4\" level=\"3\" opt=\"n\" TEIform=\"sense\"> -<foreign lang=\"greek\" TEIform=\"foreign\">κός</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">πούς</foreign>), <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ὁ</gen>, a form of anapaest in which the long syllable is shorter than a normal long, <bibl n=\"urn:cts:greekLit:tlg0081.tlg012:17\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ D.H.\">D.H.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Comp.\">Comp.</a></title_> <biblScope TEIform=\"biblScope\">17</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n60621.5\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">κυκλικοί, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">οἱ</gen></foreign>, the <tr_ opt=\"n\" TEIform=\"tr\">poets of the Epic cycle</tr_> (cf. <foreign lang=\"greek\" TEIform=\"foreign\">κύκλος</foreign>), Sch.<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:3:242\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">3.242</biblScope></bibl>, al.; also <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἡ κ. Θηβαΐς</quote_> <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:11:465e\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">11.465e</biblScope> </bibl> </cit>; but <foreign lang=\"greek\" TEIform=\"foreign\">τὸ ποίημα τὸ κ.</foreign> <tr_ opt=\"n\" TEIform=\"tr\">commonplace, conventional</tr_> poem (cf.IV), <bibl n=\"urn:cts:greekLit:tlg0533.tlg003.perseus-grc1:30:1\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Call.\">Call.</a></author> <title_ TEIform=\"title\"><a class