efault=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">946a17</biblScope> </bibl> </cit>; but <foreign lang=\"greek\" TEIform=\"foreign\">εὐδιεινὸς καὶ ἥδιστος</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0086.tlg036:943b:21\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">943b21</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὁπότε νέφεα Ζ. στυφελίξῃ</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:11:305\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">11.305</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">ἅμα πνοιῇ Ζεφύροιο θέοιμεν</foreign>, of horses, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:19:415\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">19.415</biblScope> </bibl>; later, <tr_ opt=\"n\" TEIform=\"tr\">the due West wind</tr_>, opp. <foreign lang=\"greek\" TEIform=\"foreign\">ἀπηλιώτης</foreign>, <bibl n=\"urn:cts:greekLit:tlg0086.tlg026:363b:12\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Mete.\">Mete.</a></title_> <biblScope TEIform=\"biblScope\">363b12</biblScope></bibl>, cf.<bibl n=\"urn:cts:greekLit:tlg0086.tlg028:394b:26\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Mu.\">Mu.</a></title_> <biblScope TEIform=\"biblScope\">394b26</biblScope> </bibl>; but rather <tr_ opt=\"n\" TEIform=\"tr\">northwest</tr_> in <bibl n=\"urn:cts:greekLit:tlg0086.tlg035.perseus-grc1:1290a:19\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIfor