form=\"bibl\"> <author TEIform=\"author\">Heph.Astr.</author> <biblScope TEIform=\"biblScope\">3.30</biblScope></bibl>. </sense> <sense n=\"III\" id=\"n32993.2\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">ἑκτήμορος</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">κύαθος</foreign>), <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ὁ</gen>, a <tr_ opt=\"n\" TEIform=\"tr\">liquid measure</tr_>, <bibl n=\"urn:cts:greekLit:tlg0650.tlg001:1:80\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Herod.\">Herod.</a></author> <biblScope TEIform=\"biblScope\">1.80</biblScope></bibl>.</sense> </entryFree>"}]}