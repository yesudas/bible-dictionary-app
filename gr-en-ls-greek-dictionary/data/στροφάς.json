>1032</biblScope> </bibl>; of fish, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">στροφάδες παρὰ πέτρην</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Numen.</author> </bibl> </cit> ap. <bibl n=\"urn:cts:greekLit:tlg0008.tlg001.perseus-grc1:7:319b\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ath.\">Ath.</a></author> <biblScope TEIform=\"biblScope\">7.319b</biblScope> </bibl>; of worms, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl> </sense> <sense n=\"II\" id=\"n97294.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">Στροφάδες</foreign> (sc. <foreign lang=\"greek\" TEIform=\"foreign\">νῆσοι</foreign>), <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">αἱ</gen>, <tr_ opt=\"n\" TEIform=\"tr\">the Drifting Isles</tr_>, a group not far from Zacynthus, supposed to have been once floating, <bibl n=\"urn:cts:greekLit:tlg0548.tlg001.perseus-grc1:1:9:21\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Apollod.</author> <biblScope TEIform=\"biblScope\">1.9.21</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:8:4:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Str.\">Str.</a></author> <biblScope TEIform=\"biblScope\">8.4.2</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ St.Byz.\">St.Byz.</a></author> </bibl> </sense> </entryFree>"}]}