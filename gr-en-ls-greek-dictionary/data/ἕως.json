">13.143</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:17:727\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">17.727</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:730\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">730</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:2:148\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">2.148</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἧος μὲν . . ἕποντο . . αὐτὰρ ἐπεὶ . .</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:15:277\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">15.277</biblScope> </bibl> </cit>; <tr_ opt=\"n\" TEIform=\"tr\">all that time</tr_>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:3:126\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">3.126</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:8:74\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">8.74</biblScope></bibl>. (<foreign lang=\"greek\" TEIform=\"foreign\">ἕως</foreign>, as iambus, only once in <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Hom.</author></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:2:78\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">2.78</biblScope> </bibl>; as a monosyll., <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:17:727\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">17.727</biblScope></bibl>, dub.l. in <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:2:148\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">2.148</biblScope> </bibl>; when the first syllable is to be long codd. <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Hom.</author> </bibl> have <foreign lang=\"greek\" TEIform=\"foreign\">εἵως</foreign> or <foreign lang=\"greek\" TEIform=\"foreign\">ἕως</foreign> (never <foreign lang=\"greek\" TEIform=\"foreign\">εἷος</foreign> or <foreign lang=\"greek\" TEIform=\"foreign\">ἧος</foreign>, Ludwich <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ WkP\">WkP</a></title_> <biblScope TEIform=\"biblScope\">1890.512</biblScope></bibl>, exc. <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ειος</itype> <abbr TEIform=\"abbr\">v.l.</abbr> (<bibl n=\"http://www.trismegistos.org/text/60316\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PFay.\">PFay.</a></title_> <biblScope TEIform=\"biblScope\">160</biblScope> </bibl>) in <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:20:41\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">20.41</biblScope> </bibl>), <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:3:291\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3.291</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:11:342\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11.342</biblScope></bibl>, al.; <foreign lang=\"greek\" TEIform=\"foreign\">εἵως</foreign> (or <foreign lang=\"greek\" TEIform=\"foreign\">ἕως</foreign>) is found even when the metre requires a trochee, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:1:193\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1.193</biblScope></bibl>, al.; comparison of <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Dor.\">Dor.</a></gram> </gramGrp> <foreign lang=\"greek\" TEIform=\"foreign\">ἇς</foreign> (from <foreign lang=\"greek\" TEIform=\"foreign\">Ἇος</foreign>) with <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Att.\">Att.</a></gram> </gramGrp>-<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ion.\">Ion.</a></gram> </gramGrp> <foreign lang=\"greek\" TEIform=\"foreign\">ἕως</foreign> points to early <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ion.\">Ion.</a></gram> </gramGrp> <foreign lang=\"greek\" TEIform=\"foreign\">Ἧος</foreign> (cf. Skt. <tr_ opt=\"n\" TEIform=\"tr\">yāvat</tr_> 'as great as, as long as, until') and this should prob. be restored in <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Hom.</author> </bibl>; cf. <foreign lang=\"greek\" TEIform=\"foreign\">τέως</foreign>.)</sense> </entryFree>"}]}