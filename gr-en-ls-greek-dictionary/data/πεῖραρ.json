r TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">13.359</biblScope> </bibl> </cit> : <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">Τρώεσσιν ὀλέθρου πείρατ᾽ ἐφῆπται</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:7:402\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">7.402</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πᾶσιν ὀλέθρου πείρατ᾽ ἐφῆπτο</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:22:33\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">22.33</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">καιρὸν εἰ φθέγξαιο, πολλῶν πείρατα συντανύσαις ἐν βραχεῖ</quote_> <bibl n=\"urn:cts:greekLit:tlg0033.tlg002.perseus-grc1:1:81\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ P.\">P.</a></title_> <biblScope TEIform=\"biblScope\">1.81</biblScope></bibl></cit>. (<itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">περ</itype>-<tr_ opt=\"n\" TEIform=\"tr\">Fṛ</tr_>-, <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">περ</itype>-<tr_ opt=\"n\" TEIform=\"tr\">Fṇ</tr_>-<foreign lang=\"greek\" TEIform=\"foreign\">τ-</foreign>, cogn. with <foreign lang=\"greek\" TEIform=\"foreign\">πείρω, πόρος</foreign>.)</sense> </entryFree>"}]}