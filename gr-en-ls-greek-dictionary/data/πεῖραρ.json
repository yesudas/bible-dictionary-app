{"word":"πεῖραρ","slug":"πεῖραρ","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n80346\" key=\"pei=rar\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">πεῖραρ</orth> (also <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">πεῖρας</orth>, <abbr TEIform=\"abbr\">v.</abbr> infr. <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:1:5\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1.5</biblScope> </bibl>), <itype lang=\"greek\" opt=\"n\" TEIform=\"itype\">ᾰτος</itype>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">τό</gen>, <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ep.\">Ep.</a></gram></gramGrp>, <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ion.\">Ion.</a></gram></gramGrp>, and Lyr. form of <foreign lang=\"greek\" TEIform=\"foreign\">πέρας</foreign>, <sense id=\"n80346.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">end, limit</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οὐδ᾽ εἴ κε τὰ νείατα πείραθ᾽ ἵκηαι γαίης καὶ πόντοιο</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:8:478\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">8.478</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:5:463\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">5.463</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:11:13\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">11.13</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n80346.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">completion</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">οὐ γάρ πω πάντων ἐπὶ πείρατ᾽ ἀέλων ἤλθομεν</foreign> the <tr_ opt=\"n\" TEIform=\"tr\">end</tr_> of our labours, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:23:248\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">23.248</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n80346.2\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">achievement, execution, mode</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">means of execution</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ᾧ παιδὶ ἑκάστου πείρατ᾽ ἔειπε</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:23:350\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">23.350</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πείρατ᾽ ἀέθλων δείκνυεν</quote_> <bibl n=\"urn:cts:greekLit:tlg0033.tlg002.perseus-grc1:4:220\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ P.\">P.</a></title_> <biblScope TEIform=\"biblScope\">4.220</biblScope> </bibl> </cit> ; <foreign lang=\"greek\" TEIform=\"foreign\">εἰ δέ τις ἀνδρῶν ἡμετέρης τέχνης πείρατά φησιν ἔχειν</foreign> says he possesses the <tr_ opt=\"n\" TEIform=\"tr\">secret</tr_> <pb n=\"1355\" TEIform=\"pb\"/> ( <abbr TEIform=\"abbr\">=</abbr> <tr_ opt=\"n\" TEIform=\"tr\">power of execution</tr_>) of my art, Zeuxisin <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PLG\">PLG</a></title_> <biblScope TEIform=\"biblScope\">2.318</biblScope></bibl>, cf. <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ IG\">IG</a></title_> <biblScope TEIform=\"biblScope\">3.399</biblScope> </bibl> ; <foreign lang=\"greek\" TEIform=\"foreign\">νίκης πείρατ᾽ ἔχονται ἐν ἀθανάτοισι θεοῖσι</foreign> the <tr_ opt=\"n\" TEIform=\"tr\">achievement</tr_> of victory is dependent on the gods, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:7:102\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">7.102</biblScope> </bibl> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">νίκης ἐν θεοῖσι πείρατα</quote_> <bibl n=\"urn:cts:greekLit:tlg0232.tlg001:55\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Archil.</author> <biblScope TEIform=\"biblScope\">55</biblScope></bibl></cit>. </sense> <sense n=\"4\" id=\"n80346.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">final decision, verdict</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐπὶ ἴστορι πεῖραρ ἑλέσθαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:18:501\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">18.501</biblScope></bibl></cit>. </sense> <sense n=\"5\" id=\"n80346.4\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">doom</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἐκφυγέειν μέγα π. ὀϊζύος</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:5:289\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">5.289</biblScope> </bibl> </cit> ; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὥς κεν θᾶσσον ὀλέθρου πείραθ᾽ ἵκηαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:6:143\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">6.143</biblScope> </bibl> </cit> ; <cit TEIform=\"ci