iblScope\">1.409</biblScope> </bibl>) may preserve a trace of their Aeolic origin (v. infr.). The declension <foreign lang=\"greek\" TEIform=\"foreign\">υἱῆος, υἱῆϊ, υἱῆα, υἱῆες, υἱήεσσι, υἱῆας</foreign> (like <foreign lang=\"greek\" TEIform=\"foreign\">βασιλῆος,</foreign> etc., as though from <foreign lang=\"greek\" TEIform=\"foreign\">Υἱεύς</foreign>), belongs solely to later <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Ep.\">Ep.</a></gram> </gramGrp> poets, as <bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:1093\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.R.\">A.R.</a></author> <biblScope TEIform=\"biblScope\">2.1093</biblScope></bibl>,<bibl n=\"urn:cts:greekLit:tlg0001.tlg001.perseus-grc1:2:1119\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1119</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Nic.\">Nic.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">110</biblScope></bibl>, <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\">AP</title_> <biblScope TEIform=\"biblScope\">9.23</biblScope> </bibl> (Antip.), etc. Dialect Inscrr. have the foll. archaic forms, nom. <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">υἱύς</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ IG\">IG</a></title_> <biblScope TEIform=\"biblScope\">5</biblScope> </bibl> </cit> (<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1</biblScope> </bibl>).<bibl default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">720</biblScope> </bibl> (<gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Lacon.\">Lacon.</a></gram> </gramGrp>), <bibl defa