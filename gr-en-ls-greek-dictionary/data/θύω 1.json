lg0016.tlg001.perseus-grc1:7:189\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">7.189</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0006.tlg004.perseus-grc1:340\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Heracl.\">Heracl.</a></title_> <biblScope TEIform=\"biblScope\">340</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ἐπὶ Κρότωνα, ἐπὶ τῷ Πέρσῃ</foreign>, i.e. on marching <tr_ opt=\"n\" TEIform=\"tr\">against . . </tr_>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:5:44\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">5.44</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:9:10\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">9.10</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg0032.tlg006.perseus-grc1:7:8:21\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ X.\">X.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ An.\">An.</a></title_> <biblScope TEIform=\"biblScope\">7.8.21</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">θύεσθαι ἐπ᾽ ἐξόδῳ</foreign> ib. <bibl n=\"urn:cts:greekLit:tlg0032.tlg006.perseus-grc1:6:4:9\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">6.4.9</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">ὑπὲρ τῆς μονῆς</foreign> ib.<bibl n=\"urn:cts:greekLit:tlg0032.tlg006.perseus-grc1:5:6:27\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">5.6.27</biblScope> </bibl>: c. <mood opt=\"n\" TEIform=\"mood\"><a class=\"S\" href=\"S:LSJ inf.\">inf.</a></mood>, <foreign lang=\"greek\" TEIform=\"foreign\">θ. ἰέναι</foreign> <tr_ opt=\"n\" TEI