k\" TEIform=\"foreign\">Σιληνοί</foreign>, <bibl n=\"urn:cts:greekLit:tlg0099.tlg001.perseus-grc1:10:3:15\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">10.3.15</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n104105.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> a common shepherd's name, <bibl n=\"urn:cts:greekLit:tlg0005.tlg001.perseus-grc1:3:2\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Theoc.\">Theoc.</a></author> <biblScope TEIform=\"biblScope\">3.2</biblScope></bibl>. </sense> <sense n=\"II\" id=\"n104105.2\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <foreign lang=\"greek\" TEIform=\"foreign\">τίτυρος, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ὁ</gen></foreign>, </sense> <sense n=\"1\" id=\"n104105.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <xr opt=\"n\" TEIform=\"xr\"> <lbl opt=\"n\" TEIform=\"lbl\">=</lbl> <ref targOrder=\"U\" lang=\"greek\" TEIform=\"ref\">σάτυρος</ref> </xr> <bibl n=\"urn:cts:greekLit:tlg0005.tlg001.perseus-grc1:1:3\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">1.3</biblScope></bibl>, <tr_ opt=\"n\" TEIform=\"tr\">short-tailed ape</tr_>, <bibl n=\"urn:cts:greekLit:tlg0093.tlg009:5:9\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Thphr.\">Thphr.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Char.\">Char.</a></title_> <biblScope TEIform=\"biblScope\">5.9</biblScope></bibl>, Sch. Theoc.l.c. </sense> <sense n=\"2\" id=\"n104105.4\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <gramGrp opt=\"n\" TEIform=\"gramGrp\"> <gram type=\"dialect\" opt=\"n\" TEIform=\"gram\"><a class=\"S\" href=\"S:LSJ Lacon.\">Lacon.</a></gram> </gramGrp> name for <tr_ opt=\"n\" TEIform=\"tr\">the bell-wether</tr_>, Serv.ad Verg.<tr_ opt=\"n\" TEIform=\"tr\">E. Prooem.; he-goat</tr_>, Sch.Theoc.l.c.; also called <foreign lang=\"greek\" TEIform=\"foreign\">τιτυρίς</foreign>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\">Phot.</author> </bibl> </sense> <sense n=\"3\" id=\"n104105.5\" level=\"3\" opt=\"n\" TEIform=\"sense\"> a kind of bird, also <foreign lang=\"greek\" TEIform=\"foreign\">τιτύρας</foreign>, <bibl default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hsch.\">Hsch.</a></author> </bibl>; cf. <foreign lang=\"greek\" TEIform=\"foreign\">τατύρας</foreign>. </sense> <sense n=\"4\" id=\"n104105.6\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">reed</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">pipe</tr_> (cf. <foreign lang=\"greek\" TEIform=\"foreign\">τιτύρινος</foreign>), Id.</sense> </entryFree>"}]}