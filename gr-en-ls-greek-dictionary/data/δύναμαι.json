reekLit:tlg0062.tlg036:10\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Luc.\">Luc.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Luct.\">Luct.</a></title_> <biblScope TEIform=\"biblScope\">10</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n28566.7\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of Number, etc., <tr_ opt=\"n\" TEIform=\"tr\">to be equal</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">equivalent to</tr_>, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τριηκόσιαι γενεαὶ δυνέαται μύρια ἔτεα</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:2:142\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">2.142</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">δυνήσεται τὴν ὑποτείνουσαν</foreign> <tr_ opt=\"n\" TEIform=\"tr\">will be equivalent to</tr_> the hypotenuse, <bibl n=\"urn:cts:greekLit:tlg0086.tlg015:709a:19\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ IA\">IA</a></title_> <biblScope TEIform=\"biblScope\">709a19</biblScope></bibl>. </sense> <sense n=\"3\" id=\"n28566.8\" level=\"3\" opt=\"n\" TEIform=\"sense\"> of words, <tr_ opt=\"n\" TEIform=\"tr\">signify, mean</tr_>, <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:4:110\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">4.110</biblScope></bibl>, al.; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">τὸ πειρηθῆναι καὶ τὸ ποιεῖν ἴσον δύναται</quote_> <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:6:86\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <biblScope TEIform=\"biblScope\">6.86</biblScope></bibl></cit>. <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">γ´; δύναται ἴσον τῷ δρᾶν τὸ νοεῖν</quote_> <bibl n=\"urn:cts:greekLit:tlg0019.tlg012:691\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Ar.\">Ar.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Fr.\">Fr.</a></title_> <biblScope TEIform=\"biblScope\">691</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">δύναται τὸ νεοδαμῶδες ἤδη ἐλεύθερον εἶναι</quote_> <bibl n=\"urn:cts:greekLit:tlg0003.tlg001.perseus-grc1:7:58\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></author> <biblScope TEIform=\"biblScope\">7.58</biblScope> </bibl> </cit>: in later Greek, <foreign lang=\"greek\" TEIform=\"foreign\">δύναται τὸ \"μνασθέντι\" ἀντὶ τοῦ \"μνασθέντος</foreign>\" <tr_ opt=\"n\" TEIform=\"tr\">is equivalent to</tr_>. . , Sch.<bibl n=\"urn:cts:greekLit:tlg0033.tlg001.perseus-grc1:7:110\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pi.\">Pi.</a></author> <title_ TEIform=\"title\">O.</title_> <biblScope TEIform=\"biblScope\">7.110</biblScope></bibl>. </sense> <sense n=\"b\" id=\"n28566.9\" level=\"4\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">avail to produce</tr_>, <foreign lang=\"greek\" TEIform=\"foreign\">οὐδένα καιρὸν δύναται</foreign> <tr_ opt=\"n\" TEIform=\"tr\">brings</tr_> no advantage, <bibl n=\"urn:cts:greekLit:tlg0006.tlg003.perseus-grc1:128\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ E.\">E.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Med.\">Med.</a></title_> <biblScope TEIform=\"biblScope\">128</biblScope> </bibl> (anap.), cf. <bibl n=\"urn:cts:greekLit:tlg0059.tlg010:23d\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Pl.\">Pl.</a></author> <title_ TEIform=\"ti