θη</foreign> ('modes'), <bibl n=\"urn:cts:greekLit:tlg0059.tlg001.perseus-grc1:11a\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Euthphr.\">Euthphr.</a></title_> <biblScope TEIform=\"biblScope\">11a</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πάθη οὐσίας</quote_> <bibl n=\"urn:cts:greekLit:tlg0086.tlg025.perseus-grc1:1003b:7\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Arist.\">Arist.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Metaph.\">Metaph.</a></title_> <biblScope TEIform=\"biblScope\">1003b7</biblScope> </bibl> </cit>; opp. <foreign lang=\"greek\" TEIform=\"foreign\">συμβεβηκότα</foreign> ('accidents'), <bibl n=\"urn:cts:greekLit:tlg0086.tlg001:83a:24\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ APo.\">APo.</a></title_> <biblScope TEIform=\"biblScope\">83a24</biblScope></bibl>, <bibl n=\"urn:cts:greekLit:tlg0086.tlg030:643a:27\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ PA\">PA</a></title_> <biblScope TEIform=\"biblScope\">643a27</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ἡ φύσις [τῆς ψυχῆς] καὶ ἡ οὐ., εἶθ᾽ ὅσα συμβέβηκε περὶ αὐτήν</quote_> <bibl n=\"urn:cts:greekLit:tlg0086.tlg002:402a:8\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ de An.\">de An.</a></title_> <biblScope TEIform=\"biblScope\">402a8</biblScope></bibl></cit>. </sense> <sense n=\"3\" id=\"n76029.3\" level=\"3\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">true nature</tr_> of that which is a member of a kind, defined as <cit TEIform=