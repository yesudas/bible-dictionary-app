37\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">12.37</biblScope></bibl></cit>, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:13:812\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">13.812</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">μάστιγι θείᾳ . . ἐλαύνομαι</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg003.perseus-grc1:682\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ A.\">A.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Pr.\">Pr.</a></title_> <biblScope TEIform=\"biblScope\">682</biblScope> </bibl> </cit>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">πληγεὶς θεοῦ μάστιγι</quote_> <bibl n=\"urn:cts:greekLit:tlg0085.tlg004.perseus-grc1:608\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Th.\">Th.</a></title_> <biblScope TEIform=\"biblScope\">608</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">διπλῇ μ., τὴν Ἄρης φιλεῖ</foreign>, i.e. fire and sword, <bibl n=\"urn:cts:greekLit:tlg0085.tlg005.perseus-grc1:642\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Id.\">Id.</a></author> <title_ TEIform=\"title\"><a class=\"S\" href=\"S:LSJ Ag.\">Ag.</a></title_> <biblScope TEIform=\"biblScope\">642</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">μ. [Θεοῦ]</foreign>, of sickness, <bibl n=\"urn:cts:greekLit:tlg0031.tlg002.perseus-grc1:5:34\" default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"title\">Ev.Marc.</title_> <biblScope TEIform=\"biblScope\">5.34</biblScope></bibl>, cf. <bibl n=\"urn:cts:greekLit:tlg0031.tlg002.perseus-grc1:3:10\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">3.10</biblScope> </bibl> (pl