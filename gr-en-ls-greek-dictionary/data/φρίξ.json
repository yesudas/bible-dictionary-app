{"word":"φρίξ","slug":"φρίξ","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n112340\" key=\"fri/c\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">φρίξ</orth>, <gen lang=\"greek\" opt=\"n\" TEIform=\"gen\">ἡ</gen>, gen. <foreign lang=\"greek\" TEIform=\"foreign\">φρῑκός</foreign>: (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">φρίσσω</etym>):—<sense id=\"n112340.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">ruffling</tr_> of a smooth surface. </sense> <sense n=\"I\" id=\"n112340.1\" level=\"2\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">ripple</tr_> caused by a gust of wind sweeping over the smooth sea, <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">ὑπὸ φρικὸς Βορέω</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:23:692\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">23.692</biblScope> </bibl> </cit>; <foreign lang=\"greek\" TEIform=\"foreign\">μελαίνῃ φρικὶ καλυφθείς,</foreign> of Proteus coming to the surface, <bibl n=\"urn:cts:greekLit:tlg0012.tlg002.perseus-grc1:4:402\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Od.\">Od.</a></author> <biblScope TEIform=\"biblScope\">4.402</biblScope> </bibl>; <foreign lang=\"greek\" TEIform=\"foreign\">Ζεφύροιο ἐχεύατο πόντον ἔπι φρίξ</foreign> <tr_ opt=\"n\" TEIform=\"tr\">ripple</tr_> spread over the sea from the west wind, <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:7:63\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">7.63</biblScope> </bibl>; <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">μαλακὴν φρῖκα φέροι Ζέφυρος</quote_> <bibl default=\"NO\" TEIform=\"bibl\"> <title_ TEIform=\"ti