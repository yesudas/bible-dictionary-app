{"word":"οἰμάω","slug":"οἰμάω","sections":[{"paragraph":""},{"paragraph":""},{"paragraph":"<entryFree id=\"n72426\" key=\"oi)ma/w\" type=\"main\" opt=\"n\" TEIform=\"entryFree\"> <orth extent=\"full\" lang=\"greek\" opt=\"n\" TEIform=\"orth\">οἰμ-άω</orth>, (<etym lang=\"greek\" opt=\"n\" TEIform=\"etym\">οἴμη</etym>) only <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ fut.\">fut.</a></tns> and <tns opt=\"n\" TEIform=\"tns\"><a class=\"S\" href=\"S:LSJ aor.\">aor.</a></tns>, <sense id=\"n72426.0\" n=\"A\" level=\"1\" opt=\"n\" TEIform=\"sense\"> <tr_ opt=\"n\" TEIform=\"tr\">swoop</tr_> or <tr_ opt=\"n\" TEIform=\"tr\">pounce upon,</tr_> <cit TEIform=\"cit\"> <quote_ lang=\"greek\" TEIform=\"quote\">οἴμησεν δὲ ἀλεὶς ὥς τ᾽ αἰετός</quote_> <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:22:308\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Il.\">Il.</a></author> <biblScope TEIform=\"biblScope\">22.308</biblScope></bibl></cit>, cf. <bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:311\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">311</biblScope> </bibl> ; <foreign lang=\"greek\" TEIform=\"foreign\">κίρκος . . οἴμησε μετὰ τρήρωνα πέλειαν</foreign> <tr_ opt=\"n\" TEIform=\"tr\">swooped</tr_> after a dove, ib.<bibl n=\"urn:cts:greekLit:tlg0012.tlg001.perseus-grc1:140\" default=\"NO\" TEIform=\"bibl\"> <biblScope TEIform=\"biblScope\">140</biblScope></bibl>. </sense> <sense n=\"2\" id=\"n72426.1\" level=\"3\" opt=\"n\" TEIform=\"sense\"> abs., <tr_ opt=\"n\" TEIform=\"tr\">dart along,</tr_> <foreign lang=\"greek\" TEIform=\"foreign\">θύννοι δ᾽ οἰμήσουσι</foreign> Orac. ap. <bibl n=\"urn:cts:greekLit:tlg0016.tlg001.perseus-grc1:1:62\" default=\"NO\" TEIform=\"bibl\"> <author TEIform=\"author\"><a class=\"S\" href=\"S:LSJ Hdt.\">Hdt.</a></author> <biblScope TEIform=\"biblScope\">1.62</biblScope></bibl>.</sense> </entryFree>"}]}